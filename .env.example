# Armada QR Network - Environment Configuration
# Copy to .env and fill in for local dev

# Required
JWT_SECRET=replace-with-openssl-rand-hex-32-output

# Server
PORT=3000
NODE_ENV=development

# Database (SQLite by default)
DB_PATH=./db/qrmaster.db
# Or use PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:pass@localhost:5432/armada_qr

# Files
UPLOAD_DIR=./public/uploads

# Security
BCRYPT_ROUNDS=12

# Rate limits
MAX_SCAN_RATE=15

# Public URL (auto-detected on Railway/Render/Fly.io/Vercel, set manually for custom domains)
# PUBLIC_URL=https://your-domain.com

# ═══════════════════════════════════════════════════
# DEPLOYMENT OPTIONS (pick one)
# ═══════════════════════════════════════════════════

# OPTION 1: Cloudflare Tunnel (FREE, easiest)
#   brew install cloudflare/cloudflare/cloudflared
#   cloudflared tunnel login
#   cloudflared tunnel create armada-qr
#   ./deploy-cloudflare.sh
#
# OPTION 2: Oracle Cloud Always Free (FREE, most powerful)
#   Sign up: https://cloud.oracle.com/free
#   Create ARM instance (Ubuntu 24.04)
#   ./deploy-oracle.sh <server-ip> ~/.ssh/key
#
# OPTION 3: Docker Compose (local or any VPS)
#   docker compose up -d --build
#
# OPTION 4: PM2 (direct Node.js)
#   pm2 start ecosystem.config.js
#   pm2 save
#   pm2 startup

# ═══════════════════════════════════════════════════
# RAILWAY (limited free tier, 500h/month)
# ═══════════════════════════════════════════════════
# 1. Add PostgreSQL add-on in Railway dashboard
# 2. Set DATABASE_URL from the PostgreSQL add-on
# 3. PUBLIC_URL is auto-detected from RAILWAY_PUBLIC_DOMAIN
# 4. JWT_SECRET is auto-generated on first start (set for persistence)
# 5. Uploads are ephemeral on Railway - use external storage (S3) for production

# ═══════════════════════════════════════════════════
# BACKUPS
# ═══════════════════════════════════════════════════
# Local:    ./backup-db.sh
# Remote:   ./backup-db.sh <server-ip> ~/.ssh/key
# Auto:     ./backup-db.sh --cron (daily at 3am)
