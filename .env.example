# Example env for local dev
# Copy to .env and fill in

# Required
JWT_SECRET=replace-with-openssl-rand-hex-32-output

# Server
PORT=3000
NODE_ENV=development

# Database (SQLite by default)
DB_PATH=./db/qrmaster.db
# Or use PostgreSQL:
# DATABASE_URL=postgresql://user:pass@localhost:5432/armada_qr

# Files
UPLOAD_DIR=./public/uploads

# Security
BCRYPT_ROUNDS=12

# Rate limits
MAX_SCAN_RATE=15

# Public URL (used in QR codes for the public scan page)
# PUBLIC_URL=https://your-domain.com
