# Armada QR Network - Environment Configuration
# Copy to .env and fill in for local dev

# Required
JWT_SECRET=replace-with-openssl-rand-hex-32-output

# Server
PORT=3000
NODE_ENV=development

# Database (SQLite by default)
DB_PATH=./db/qrmaster.db
# Or use PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:pass@localhost:5432/armada_qr

# Files
UPLOAD_DIR=./public/uploads

# Security
BCRYPT_ROUNDS=12

# Rate limits
MAX_SCAN_RATE=15

# Public URL (auto-detected on Railway/Render/Fly.io/Vercel, set manually for custom domains)
# PUBLIC_URL=https://your-domain.com

# ═══════════════════════════════════════════════════
# RAILWAY DEPLOYMENT
# ═══════════════════════════════════════════════════
# 1. Add PostgreSQL add-on in Railway dashboard
# 2. Set DATABASE_URL from the PostgreSQL add-on
# 3. PUBLIC_URL is auto-detected from RAILWAY_PUBLIC_DOMAIN
# 4. JWT_SECRET is auto-generated on first start (set for persistence)
# 5. Uploads are ephemeral on Railway - use external storage (S3) for production
#
# Railway variables (auto-set by Railway):
#   RAILWAY_PUBLIC_DOMAIN  - your app's public domain
#   DATABASE_URL           - PostgreSQL connection string
#   PORT                   - server port
