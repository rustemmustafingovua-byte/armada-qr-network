<%- include('partials/header') %>
<div class="max-w-md mx-auto mt-8 sm:mt-16 px-4 fade-in">
  <div class="bg-white dark:bg-slate-900 p-8 rounded-2xl shadow-card dark:shadow-2xl border border-slate-200/60 dark:border-slate-800/60 text-center">
    <div class="w-16 h-16 mx-auto rounded-2xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center mb-5">
      <i data-lucide="clock" class="w-8 h-8 text-slate-400"></i>
    </div>
    <h1 class="text-xl font-bold mb-2 text-slate-900 dark:text-white">No Longer Available</h1>
    <p class="text-slate-500 dark:text-slate-400 text-base"><%= typeof reason !== 'undefined' ? reason : 'This QR code is no longer available.' %></p>
  </div>
</div>
<script>document.addEventListener('DOMContentLoaded', function() { if (window.lucide) lucide.createIcons(); });</script>
<%- include('partials/footer') %>
