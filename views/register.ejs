<%- include('partials/header') %>
<div class="auth-split">
  <!-- Brand Panel -->
  <div class="auth-brand-panel gradient-primary relative hidden lg:flex gradient-mesh-animated">
    <div class="relative z-10 text-center max-w-md">
      <div class="w-20 h-20 rounded-2xl bg-white/20 backdrop-blur-sm flex items-center justify-center mx-auto mb-8 shadow-lg">
        <i data-lucide="qr-code" class="w-10 h-10 text-white"></i>
      </div>
      <h2 class="text-3xl font-bold text-white mb-4 tracking-tight">Start Creating QR Codes</h2>
      <p class="text-white/80 text-lg leading-relaxed">Join thousands of teams using Armada QR for dynamic, trackable QR code management.</p>
      <div class="grid grid-cols-3 gap-4 mt-10">
        <div class="text-center">
          <p class="text-2xl font-bold text-white">6</p>
          <p class="text-white/60 text-xs">Content Types</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-white">∞</p>
          <p class="text-white/60 text-xs">QR Codes</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-white">24/7</p>
          <p class="text-white/60 text-xs">Analytics</p>
        </div>
      </div>
    </div>
    <div class="absolute bottom-8 left-0 right-0 text-center">
      <p class="text-white/40 text-xs">&copy; 2026 Armada QR Network</p>
    </div>
  </div>

  <!-- Form Panel -->
  <div class="flex items-center justify-center px-4 py-12 sm:px-8 bg-white dark:bg-slate-950">
    <div class="w-full max-w-md fade-in">
      <!-- Mobile Logo -->
      <div class="lg:hidden text-center mb-8">
        <div class="w-14 h-14 rounded-xl gradient-primary flex items-center justify-center mx-auto mb-4 shadow-glow">
          <i data-lucide="qr-code" class="w-7 h-7 text-white"></i>
        </div>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Armada<span class="text-brand-500">QR</span></h1>
      </div>

      <div class="bg-slate-50 dark:bg-slate-900 rounded-2xl p-8 shadow-card border border-slate-200/60 dark:border-slate-800/60">
        <div class="mb-6">
          <h1 class="text-xl font-bold text-slate-900 dark:text-white">Create account</h1>
          <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Get started with Armada QR</p>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="flex items-center gap-2 bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 text-red-700 dark:text-red-400 px-4 py-3 rounded-xl mb-5 text-sm slide-down">
            <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i>
            <span><%- error %></span>
          </div>
        <% } %>

        <form method="POST" action="/register" onsubmit="document.getElementById('reg-btn').disabled=true;document.getElementById('reg-btn').innerHTML='<span class=\\'spinner\\'></span>'">
          <input type="hidden" name="_csrf" value="<%= _csrf %>">
          <div class="mb-4">
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Name</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <i data-lucide="user" class="w-4 h-4 text-slate-400"></i>
              </div>
              <input type="text" name="name" maxlength="100" value="<%= typeof name !== 'undefined' ? name : '' %>" placeholder="Your name" class="w-full pl-10 pr-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
            </div>
          </div>
          <div class="mb-4">
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Email</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <i data-lucide="mail" class="w-4 h-4 text-slate-400"></i>
              </div>
              <input type="email" name="email" required value="<%= typeof email !== 'undefined' ? email : '' %>" autocomplete="email" placeholder="you@example.com" class="w-full pl-10 pr-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
            </div>
          </div>
          <div class="mb-5">
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Password</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <i data-lucide="lock" class="w-4 h-4 text-slate-400"></i>
              </div>
              <input type="password" name="password" required minlength="8" autocomplete="new-password" placeholder="Min 8 characters" oninput="checkStrength(this.value)" class="w-full pl-10 pr-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
            </div>
            <div id="password-strength" class="mt-2 hidden">
              <div class="flex gap-1">
                <div id="str-1" class="h-1 flex-1 rounded-full bg-slate-200 dark:bg-slate-700"></div>
                <div id="str-2" class="h-1 flex-1 rounded-full bg-slate-200 dark:bg-slate-700"></div>
                <div id="str-3" class="h-1 flex-1 rounded-full bg-slate-200 dark:bg-slate-700"></div>
                <div id="str-4" class="h-1 flex-1 rounded-full bg-slate-200 dark:bg-slate-700"></div>
              </div>
              <p id="str-text" class="text-xs mt-1 text-slate-400"></p>
            </div>
          </div>
          <button id="reg-btn" type="submit" class="w-full bg-gradient-to-r from-brand-600 to-violet-600 text-white py-2.5 rounded-xl hover:from-brand-700 hover:to-violet-700 font-semibold text-sm transition-all btn-scale shadow-glow hover:shadow-glow-lg">
            Create Account
          </button>
        </form>
      </div>

      <p class="text-center text-sm text-slate-500 dark:text-slate-400 mt-6">
        Already have an account?
        <a href="/login" class="font-semibold text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300 transition-colors">Sign in</a>
      </p>
    </div>
  </div>
</div>

<script>
function checkStrength(pw) {
  var el = document.getElementById('password-strength');
  if (!pw) { el.classList.add('hidden'); return; }
  el.classList.remove('hidden');
  var score = 0;
  if (pw.length >= 8) score++;
  if (pw.length >= 12) score++;
  if (/[A-Z]/.test(pw) && /[a-z]/.test(pw)) score++;
  if (/[0-9]/.test(pw)) score++;
  if (/[^A-Za-z0-9]/.test(pw)) score++;
  score = Math.min(score, 4);
  var colors = ['bg-red-500', 'bg-orange-500', 'bg-yellow-500', 'bg-emerald-500'];
  var labels = ['Weak', 'Fair', 'Good', 'Strong'];
  for (var i = 1; i <= 4; i++) {
    var bar = document.getElementById('str-' + i);
    bar.className = 'h-1 flex-1 rounded-full transition-colors ' + (i <= score ? colors[score - 1] : 'bg-slate-200 dark:bg-slate-700');
  }
  document.getElementById('str-text').textContent = score > 0 ? labels[score - 1] : '';
}
</script>
<%- include('partials/footer') %>
