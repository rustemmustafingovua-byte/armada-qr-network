<%- include('partials/header') %>
<div class="max-w-md mx-auto mt-16 fade-in">
  <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-md dark:shadow-2xl">
    <h1 class="text-2xl font-bold text-center mb-6 dark:text-white">Create Account</h1>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-100 dark:bg-red-900 border border-red-400 dark:border-red-700 text-red-700 dark:text-red-300 px-4 py-3 rounded mb-4 text-sm"><%- error %></div>
    <% } %>
    <form method="POST" action="/register" onsubmit="document.getElementById('reg-btn').disabled=true;document.getElementById('reg-btn').innerHTML='<span class=\\'spinner\\'></span>'">
      <input type="hidden" name="_csrf" value="<%= _csrf %>">
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Name</label>
        <input type="text" name="name" maxlength="100" value="<%= typeof name !== 'undefined' ? name : '' %>" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Email</label>
        <input type="email" name="email" required value="<%= typeof email !== 'undefined' ? email : '' %>" autocomplete="email" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Password</label>
        <input type="password" name="password" required minlength="8" autocomplete="new-password" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Min 8 characters, must include letters and numbers</p>
      </div>
      <button id="reg-btn" type="submit" class="w-full bg-indigo-600 text-white py-2.5 rounded-lg hover:bg-indigo-700 font-medium transition-colors">Create Account</button>
    </form>
    <p class="text-center text-sm text-gray-500 dark:text-gray-400 mt-4">Already have an account? <a href="/login" class="text-indigo-600 dark:text-indigo-400 hover:underline">Sign in</a></p>
  </div>
</div>
<%- include('partials/footer') %>
