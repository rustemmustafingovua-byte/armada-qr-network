<%- include('partials/header') %>
<div class="max-w-2xl mx-auto text-center">
  <div class="bg-white p-6 sm:p-8 rounded-xl shadow-sm border">
    <div class="text-4xl mb-2">✅</div>
    <h1 class="text-2xl font-bold text-green-600 mb-2">QR Code Created!</h1>
    <p class="text-gray-500 mb-6 break-words">"<%= title %>"</p>

    <img src="<%= qrImage %>" alt="QR Code" class="mx-auto w-56 h-56 sm:w-64 sm:h-64 border-2 border-gray-200 rounded-lg p-2 mb-6 bg-white">

    <div class="bg-gray-50 rounded-lg p-4 mb-6 text-left space-y-3">
      <div>
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">QR URL (scan to open)</p>
        <a href="<%= qrUrl %>" target="_blank" class="text-indigo-600 hover:underline break-all text-sm"><%= qrUrl %></a>
      </div>
      <div>
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Short ID</p>
        <code class="bg-gray-200 px-2 py-1 rounded text-sm font-mono"><%= id %></code>
      </div>
      <% if (baseUrl.includes('localhost')) { %>
      <div class="bg-yellow-50 border border-yellow-200 rounded p-3 text-xs text-yellow-700">
        ⚠️ This QR uses localhost &mdash; it will only work on this computer.
        Scan from another device? Replace <code class="bg-yellow-100 px-1">localhost:3000</code> with your computer's IP address
        (e.g., <code class="bg-yellow-100 px-1">192.168.1.100:3000</code>).
      </div>
      <% } %>
    </div>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/dashboard" class="bg-indigo-600 text-white px-6 py-2.5 rounded-lg hover:bg-indigo-700 font-medium text-sm btn-scale">Back to Dashboard</a>
      <a href="/create" class="bg-gray-200 text-gray-700 px-6 py-2.5 rounded-lg hover:bg-gray-300 font-medium text-sm btn-scale">Create Another</a>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
