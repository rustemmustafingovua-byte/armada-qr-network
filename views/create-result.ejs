<%- include('partials/header') %>
<div class="max-w-2xl mx-auto text-center fade-in-scale">
  <!-- Success Header -->
  <div class="mb-8">
    <div class="w-20 h-20 mx-auto rounded-2xl bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center mb-6 shadow-lg">
      <i data-lucide="check" class="w-10 h-10 text-white"></i>
    </div>
    <h1 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">QR Code Created!</h1>
    <p class="text-slate-500 dark:text-slate-400 break-words">"<%= title %>"</p>
  </div>

  <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 sm:p-8 shadow-card border border-slate-200/60 dark:border-slate-800/60">
    <!-- QR Image -->
    <div class="inline-block p-4 bg-white rounded-2xl shadow-card mb-6 border border-slate-100">
      <img src="<%= qrImage %>" alt="QR Code" class="w-56 h-56 sm:w-64 sm:h-64">
    </div>

    <!-- Action Buttons -->
    <div class="grid grid-cols-2 sm:grid-cols-5 gap-2 mb-6">
      <button onclick="downloadPNG()" class="flex items-center justify-center gap-1.5 bg-gradient-to-r from-brand-600 to-violet-600 text-white px-4 py-2.5 rounded-xl hover:from-brand-700 hover:to-violet-700 text-sm font-medium btn-scale shadow-glow col-span-2 sm:col-span-1">
        <i data-lucide="download" class="w-4 h-4"></i> PNG
      </button>
      <a href="/qr-svg/<%= id %>" class="flex items-center justify-center gap-1.5 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 px-4 py-2.5 rounded-xl hover:bg-slate-200 dark:hover:bg-slate-700 text-sm font-medium transition-all">
        <i data-lucide="download" class="w-4 h-4"></i> SVG
      </a>
      <a href="/qr-png/<%= id %>" class="flex items-center justify-center gap-1.5 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 px-4 py-2.5 rounded-xl hover:bg-slate-200 dark:hover:bg-slate-700 text-sm font-medium transition-all">
        <i data-lucide="image" class="w-4 h-4"></i> High-res
      </a>
      <button onclick="copyToClipboard('<%= qrUrl %>')" class="flex items-center justify-center gap-1.5 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 px-4 py-2.5 rounded-xl hover:bg-slate-200 dark:hover:bg-slate-700 text-sm font-medium transition-all">
        <i data-lucide="copy" class="w-4 h-4"></i> Copy URL
      </button>
      <button onclick="window.print()" class="flex items-center justify-center gap-1.5 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 px-4 py-2.5 rounded-xl hover:bg-slate-200 dark:hover:bg-slate-700 text-sm font-medium transition-all">
        <i data-lucide="printer" class="w-4 h-4"></i> Print
      </button>
    </div>

    <!-- Info Cards -->
    <div class="bg-slate-50 dark:bg-slate-800/50 rounded-xl p-5 mb-6 text-left space-y-4 border border-slate-100 dark:border-slate-800">
      <div>
        <p class="text-[11px] font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider mb-1.5">QR URL (scan to open)</p>
        <a href="<%= qrUrl %>" target="_blank" class="text-brand-600 dark:text-brand-400 hover:underline break-all text-sm font-mono flex items-center gap-2">
          <i data-lucide="external-link" class="w-3.5 h-3.5 flex-shrink-0"></i>
          <%= qrUrl %>
        </a>
      </div>
      <% if (typeof verifyCode !== 'undefined' && verifyCode) { %>
      <div class="pt-3 border-t border-slate-200 dark:border-slate-700">
        <p class="text-[11px] font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider mb-1.5">Verification Code</p>
        <div class="flex items-center gap-2">
          <code class="bg-amber-100 dark:bg-amber-500/10 text-amber-700 dark:text-amber-400 px-3 py-1.5 rounded-lg text-lg font-bold font-mono select-all"><%= verifyCode %></code>
        </div>
        <p class="text-xs text-slate-400 dark:text-slate-500 mt-1.5">Users need this code to view/download files</p>
      </div>
      <% } %>
      <% if (typeof password !== 'undefined' && password) { %>
      <div class="pt-3 border-t border-slate-200 dark:border-slate-700">
        <p class="text-[11px] font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider mb-1.5">Password</p>
        <code class="bg-slate-200 dark:bg-slate-700 px-3 py-1.5 rounded-lg font-mono text-sm text-slate-700 dark:text-slate-300 select-all"><%= password %></code>
      </div>
      <% } %>
      <div class="pt-3 border-t border-slate-200 dark:border-slate-700">
        <p class="text-[11px] font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider mb-1.5">Short ID</p>
        <code class="bg-slate-200 dark:bg-slate-700 px-3 py-1.5 rounded-lg text-sm font-mono text-slate-700 dark:text-slate-300 select-all"><%= id %></code>
      </div>
    </div>

    <!-- Uploaded Files -->
    <% if (typeof uploadedFiles !== 'undefined' && uploadedFiles.length > 0) { %>
    <div class="bg-slate-50 dark:bg-slate-800/50 rounded-xl p-5 mb-6 text-left border border-slate-100 dark:border-slate-800">
      <p class="text-[11px] font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider mb-3">Uploaded Files</p>
      <% uploadedFiles.forEach(function(f) { %>
      <div class="flex items-center justify-between bg-white dark:bg-slate-900 rounded-xl px-4 py-3 mb-2 border border-slate-100 dark:border-slate-800 last:mb-0">
        <div class="flex items-center gap-3 min-w-0">
          <div class="w-10 h-10 rounded-lg bg-brand-50 dark:bg-brand-500/10 flex items-center justify-center flex-shrink-0">
            <i data-lucide="file" class="w-5 h-5 text-brand-500"></i>
          </div>
          <div class="min-w-0">
            <p class="text-sm font-medium text-slate-900 dark:text-white truncate"><%= f.original_name %></p>
            <p class="text-xs text-slate-400"><%= f.original_size > 1048576 ? (f.original_size / 1048576).toFixed(1) + ' MB' : f.original_size > 1024 ? (f.original_size / 1024).toFixed(1) + ' KB' : f.original_size + ' B' %></p>
          </div>
        </div>
        <a href="/d/<%= f.id %><%= typeof verifyCode !== 'undefined' && verifyCode ? '?code=' + encodeURIComponent(verifyCode) : '' %>"
           class="flex items-center gap-1.5 bg-brand-600 text-white px-4 py-2 rounded-xl hover:bg-brand-700 text-xs font-medium whitespace-nowrap ml-3 btn-scale">
          <i data-lucide="download" class="w-3.5 h-3.5"></i> Download
        </a>
      </div>
      <% }); %>
    </div>
    <% } %>

    <!-- Navigation -->
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/dashboard" class="flex items-center justify-center gap-2 bg-gradient-to-r from-brand-600 to-violet-600 text-white px-6 py-2.5 rounded-xl hover:from-brand-700 hover:to-violet-700 font-semibold text-sm btn-scale shadow-glow hover:shadow-glow-lg">
        <i data-lucide="layout-dashboard" class="w-4 h-4"></i> Back to Dashboard
      </a>
      <a href="/create" class="flex items-center justify-center gap-2 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 px-6 py-2.5 rounded-xl hover:bg-slate-200 dark:hover:bg-slate-700 font-semibold text-sm transition-all">
        <i data-lucide="plus" class="w-4 h-4"></i> Create Another
      </a>
    </div>
  </div>
</div>

<div id="toast-container" class="fixed bottom-4 right-4 z-50 space-y-2"></div>
<script>
function copyToClipboard(text) {
  navigator.clipboard.writeText(text).then(function() { showToast('Copied!', 'success'); }).catch(function() { showToast('Copy failed', 'error'); });
}
function downloadPNG() {
  var img = document.querySelector('img[alt="QR Code"]');
  var a = document.createElement('a');
  a.href = img.src;
  a.download = 'qr-<%= id %>.png';
  a.click();
  showToast('Downloaded!', 'success');
}
function showToast(message, type) {
  var c = document.getElementById('toast-container');
  var t = document.createElement('div');
  t.className = 'toast-enter flex items-center gap-2 px-4 py-3 rounded-xl shadow-lg text-sm font-medium ' + (type === 'error' ? 'bg-red-500 text-white' : 'bg-emerald-500 text-white');
  t.textContent = message;
  c.appendChild(t);
  setTimeout(function() { t.style.opacity = '0'; t.style.transition = 'opacity 0.3s'; setTimeout(function() { t.remove(); }, 300); }, 2500);
}
document.addEventListener('DOMContentLoaded', function() { if (window.lucide) lucide.createIcons(); });
</script>
<%- include('partials/footer') %>
