<%- include('partials/header') %>
<div class="max-w-2xl mx-auto text-center fade-in">
  <div class="bg-white dark:bg-gray-800 p-6 sm:p-8 rounded-xl shadow-sm border dark:border-gray-700">
    <div class="text-4xl mb-2">✅</div>
    <h1 class="text-2xl font-bold text-green-600 dark:text-green-400 mb-2">QR Code Created!</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-6 break-words">"<%= title %>"</p>

    <img src="<%= qrImage %>" alt="QR Code" class="mx-auto w-56 h-56 sm:w-64 sm:h-64 border-2 border-gray-200 dark:border-gray-600 rounded-lg p-2 mb-4 bg-white">

    <div class="flex flex-wrap gap-2 justify-center mb-6">
      <button onclick="downloadPNG()" class="btn-scale bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 text-sm font-medium">⬇ PNG</button>
      <a href="/qr-svg/<%= id %>" class="btn-scale bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 px-4 py-2 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600 text-sm font-medium">⬇ SVG</a>
      <a href="/qr-png/<%= id %>" class="btn-scale bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 px-4 py-2 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600 text-sm font-medium">⬇ High-res PNG</a>
      <button onclick="copyToClipboard('<%= qrUrl %>')" class="btn-scale bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 px-4 py-2 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600 text-sm font-medium">📋 Copy URL</button>
      <button onclick="window.print()" class="btn-scale bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 px-4 py-2 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600 text-sm font-medium">🖨 Print</button>
    </div>

    <div class="bg-gray-50 dark:bg-gray-900 rounded-lg p-4 mb-6 text-left space-y-3">
      <div>
        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">QR URL (scan to open)</p>
        <a href="<%= qrUrl %>" target="_blank" class="text-indigo-600 dark:text-indigo-400 hover:underline break-all text-sm font-mono"><%= qrUrl %></a>
      </div>
      <% if (typeof verifyCode !== 'undefined' && verifyCode) { %>
      <div>
        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Verification Code</p>
        <code class="bg-amber-100 dark:bg-amber-900 text-amber-800 dark:text-amber-300 px-3 py-1.5 rounded text-lg font-bold font-mono select-all"><%= verifyCode %></code>
        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Users need this code to view/download files</p>
      </div>
      <% } %>
      <% if (typeof password !== 'undefined' && password) { %>
      <div>
        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Password</p>
        <code class="bg-gray-200 dark:bg-gray-700 px-2 py-1 rounded font-mono text-sm dark:text-gray-200 select-all"><%= password %></code>
      </div>
      <% } %>
      <div>
        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Short ID</p>
        <code class="bg-gray-200 dark:bg-gray-700 px-2 py-1 rounded text-sm font-mono dark:text-gray-200 select-all"><%= id %></code>
      </div>
    </div>

    <% if (typeof uploadedFiles !== 'undefined' && uploadedFiles.length > 0) { %>
    <div class="bg-gray-50 dark:bg-gray-900 rounded-lg p-4 mb-6 text-left">
      <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-3">Uploaded Files</p>
      <% uploadedFiles.forEach(function(f) { %>
      <div class="flex items-center justify-between bg-white dark:bg-gray-800 rounded-lg px-3 py-2 mb-2 border dark:border-gray-700">
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium dark:text-white truncate"><%= f.original_name %></p>
          <p class="text-xs text-gray-400"><%= f.original_size > 1048576 ? (f.original_size / 1048576).toFixed(1) + ' MB' : f.original_size > 1024 ? (f.original_size / 1024).toFixed(1) + ' KB' : f.original_size + ' B' %></p>
        </div>
        <a href="/d/<%= f.id %><%= typeof verifyCode !== 'undefined' && verifyCode ? '?code=' + encodeURIComponent(verifyCode) : '' %>"
           class="btn-scale bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 text-xs font-medium whitespace-nowrap ml-3">
          Download
        </a>
      </div>
      <% }); %>
    </div>
    <% } %>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/dashboard" class="bg-indigo-600 text-white px-6 py-2.5 rounded-lg hover:bg-indigo-700 font-medium text-sm btn-scale">Back to Dashboard</a>
      <a href="/create" class="bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 px-6 py-2.5 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600 font-medium text-sm btn-scale">Create Another</a>
    </div>
  </div>
</div>

<div id="toast-container" class="fixed bottom-4 right-4 z-50 space-y-2"></div>
<script>
function copyToClipboard(text) {
  navigator.clipboard.writeText(text).then(function() { showToast('Copied!', 'success'); }).catch(function() { showToast('Copy failed', 'error'); });
}
function downloadPNG() {
  var img = document.querySelector('img[alt="QR Code"]');
  var a = document.createElement('a');
  a.href = img.src;
  a.download = 'qr-<%= id %>.png';
  a.click();
  showToast('Downloaded!', 'success');
}
function showToast(message, type) {
  var c = document.getElementById('toast-container');
  var t = document.createElement('div');
  t.className = 'px-4 py-2 rounded-lg shadow-lg text-sm font-medium ' + (type === 'error' ? 'bg-red-600 text-white' : 'bg-green-600 text-white');
  t.textContent = message;
  c.appendChild(t);
  setTimeout(function() { t.style.opacity = '0'; t.style.transition = 'opacity 0.3s'; setTimeout(function() { t.remove(); }, 300); }, 2500);
}
</script>
<%- include('partials/footer') %>
