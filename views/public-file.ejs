<%- include('partials/header') %>
<div class="max-w-lg mx-auto mt-8 sm:mt-16 px-2 fade-in">
  <div class="bg-white dark:bg-gray-800 p-6 sm:p-8 rounded-xl shadow-md dark:shadow-2xl border dark:border-gray-700 text-center">
    <div class="text-5xl mb-4">📄</div>
    <h1 class="text-xl font-bold mb-2 break-words dark:text-white"><%= title || 'File Download' %></h1>
    <p class="text-gray-500 dark:text-gray-400 text-sm mb-6">Your file is ready</p>
    <div class="bg-gray-50 dark:bg-gray-900 rounded-lg p-4 mb-6">
      <p class="text-sm text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-1">File name</p>
      <p class="text-base font-semibold text-gray-700 dark:text-gray-200 break-all"><%= fileName %></p>
    </div>
    <a href="/download/<%= fileId %>" class="btn-scale block w-full bg-indigo-600 text-white py-4 rounded-lg hover:bg-indigo-700 font-medium text-center text-lg transition-colors">
      Download File
    </a>
    <p class="text-xs text-gray-400 dark:text-gray-500 mt-4">The file will be downloaded to your device</p>
  </div>
</div>
<%- include('partials/footer') %>
