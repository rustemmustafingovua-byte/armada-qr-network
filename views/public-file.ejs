<%- include('partials/header') %>
<div class="max-w-2xl mx-auto mt-4 sm:mt-8 px-2 fade-in">
  <div class="bg-white dark:bg-gray-800 p-4 sm:p-6 rounded-xl shadow-md dark:shadow-2xl border dark:border-gray-700">
    <div class="text-center mb-6">
      <div class="text-5xl mb-3">📁</div>
      <h1 class="text-xl font-bold dark:text-white break-words"><%= title %></h1>
      <p class="text-gray-500 dark:text-gray-400 text-sm mt-1">Files available for download</p>
    </div>

    <% if (hasVerifyCode && !verified) { %>
    <div id="verify-section" class="bg-gray-50 dark:bg-gray-900 rounded-lg p-5 mb-6 border dark:border-gray-700">
      <h3 class="font-semibold text-gray-700 dark:text-gray-300 mb-3">Verification Required</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Enter the verification code to access files and send messages</p>
      <div class="flex gap-2">
        <input type="text" id="verify-code-input" placeholder="Enter verification code" class="flex-1 px-3 py-2.5 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        <button onclick="verifyCode()" id="verify-btn" class="bg-indigo-600 text-white px-5 py-2.5 rounded-lg hover:bg-indigo-700 font-medium text-sm btn-scale">Verify</button>
      </div>
      <p id="verify-error" class="text-red-500 text-sm mt-2 hidden"></p>
    </div>
    <% } %>

    <div id="content-section" class="<%= hasVerifyCode && !verified ? 'hidden' : '' %>">
      <% if (files.length === 0) { %>
      <div class="text-center py-8">
        <p class="text-gray-400 dark:text-gray-500">No files attached to this QR code</p>
      </div>
      <% } else { %>
      <div class="space-y-2 mb-6">
        <% files.forEach(function(f) { %>
        <div class="flex items-center justify-between bg-gray-50 dark:bg-gray-900 rounded-lg px-4 py-3 border dark:border-gray-700">
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium dark:text-white truncate"><%= f.original_name %></p>
            <p class="text-xs text-gray-400 dark:text-gray-500">
              <%= f.original_size > 1048576 ? (f.original_size / 1048576).toFixed(1) + ' MB' : f.original_size > 1024 ? (f.original_size / 1024).toFixed(1) + ' KB' : f.original_size + ' B' %>
            </p>
          </div>
          <a href="/download/<%= f.id %><%= verified ? '?code=' + encodeURIComponent(window.__verifyCode || '') : '' %>"
             class="btn-scale bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 text-xs font-medium whitespace-nowrap ml-3">
            Download
          </a>
        </div>
        <% }) %>
      </div>
      <% } %>

      <hr class="border-gray-200 dark:border-gray-700 my-6">

      <div id="chat-section">
        <h3 class="font-semibold text-gray-700 dark:text-gray-300 mb-3">💬 Messages</h3>
        <p class="text-xs text-gray-400 dark:text-gray-500 mb-4">Send a message to the QR code owner</p>

        <div id="chat-messages" class="space-y-3 mb-4 max-h-80 overflow-y-auto"></div>

        <div class="flex gap-2 mb-2">
          <input type="text" id="chat-name" placeholder="Your name (optional)" maxlength="100" class="w-1/3 px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          <input type="text" id="chat-input" placeholder="Type your message..." maxlength="2000" class="flex-1 px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          <button onclick="sendMessage()" id="chat-send-btn" class="bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 font-medium text-sm btn-scale">Send</button>
        </div>
        <p id="chat-status" class="text-xs text-gray-400 hidden"></p>
      </div>
    </div>
  </div>
</div>

<script>
window.__verifyCode = '';
var qrId = '<%= qrId %>';

function verifyCode() {
  var code = document.getElementById('verify-code-input').value.trim();
  if (!code) { document.getElementById('verify-error').textContent = 'Enter verification code'; document.getElementById('verify-error').classList.remove('hidden'); return; }

  var btn = document.getElementById('verify-btn');
  btn.disabled = true; btn.textContent = 'Verifying...';

  fetch('/api/verify-code/' + qrId, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ code: code })
  })
  .then(function(r) { return r.json(); })
  .then(function(d) {
    if (d.valid) {
      window.__verifyCode = code;
      document.getElementById('verify-section').classList.add('hidden');
      document.getElementById('content-section').classList.remove('hidden');
      loadMessages();
    } else {
      document.getElementById('verify-error').textContent = d.error || 'Invalid code';
      document.getElementById('verify-error').classList.remove('hidden');
      btn.disabled = false; btn.textContent = 'Verify';
    }
  })
  .catch(function() {
    document.getElementById('verify-error').textContent = 'Verification failed';
    document.getElementById('verify-error').classList.remove('hidden');
    btn.disabled = false; btn.textContent = 'Verify';
  });
}

function sendMessage() {
  var name = document.getElementById('chat-name').value.trim() || 'Anonymous';
  var msg = document.getElementById('chat-input').value.trim();
  if (!msg) return;

  var btn = document.getElementById('chat-send-btn');
  btn.disabled = true; btn.textContent = 'Sending...';

  fetch('/api/messages/' + qrId, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ name: name, message: msg })
  })
  .then(function(r) { return r.json(); })
  .then(function(d) {
    if (d.success) {
      document.getElementById('chat-input').value = '';
      addMessage(d.message, true);
    }
    btn.disabled = false; btn.textContent = 'Send';
  })
  .catch(function() {
    btn.disabled = false; btn.textContent = 'Send';
  });
}

function addMessage(msg, isNew) {
  var container = document.getElementById('chat-messages');
  var div = document.createElement('div');
  div.className = 'bg-gray-50 dark:bg-gray-900 rounded-lg px-3 py-2 border dark:border-gray-700' + (isNew ? ' border-indigo-300 dark:border-indigo-600' : '');
  div.innerHTML = '<div class="flex justify-between items-start"><span class="text-xs font-semibold text-indigo-600 dark:text-indigo-400">' + escapeHtml(msg.sender_name) + '</span><span class="text-xs text-gray-400">' + (msg.created_at || 'just now') + '</span></div><p class="text-sm dark:text-white mt-1">' + escapeHtml(msg.message) + '</p>';
  if (msg.reply) {
    div.innerHTML += '<div class="mt-2 pl-3 border-l-2 border-indigo-400 bg-indigo-50 dark:bg-indigo-900/30 rounded-r px-2 py-1"><span class="text-xs font-medium text-indigo-600 dark:text-indigo-400">Reply:</span><p class="text-sm dark:text-gray-200">' + escapeHtml(msg.reply) + '</p></div>';
  }
  container.appendChild(div);
  container.scrollTop = container.scrollHeight;
}

function loadMessages() {
  fetch('/api/messages/' + qrId + '/public')
  .then(function(r) { return r.json(); })
  .then(function(d) {
    if (d.messages) {
      document.getElementById('chat-messages').innerHTML = '';
      d.messages.forEach(function(m) { addMessage(m, false); });
    }
  });
}

function escapeHtml(text) {
  var d = document.createElement('div');
  d.textContent = text || '';
  return d.innerHTML;
}

<% if (verified) { %>
window.__verifyCode = '<%= typeof verifyCode !== 'undefined' ? verifyCode : '' %>';
loadMessages();
<% } %>
</script>
<%- include('partials/footer') %>
