<%- include('partials/header') %>
<div class="max-w-2xl mx-auto mt-4 sm:mt-8 px-2 fade-in">
  <div class="bg-white dark:bg-slate-900 p-5 sm:p-6 rounded-2xl shadow-card dark:shadow-2xl border border-slate-200/60 dark:border-slate-800/60">
    <div class="text-center mb-6">
      <div class="w-14 h-14 mx-auto rounded-2xl bg-brand-50 dark:bg-brand-500/10 flex items-center justify-center mb-3">
        <i data-lucide="folder-open" class="w-7 h-7 text-brand-500"></i>
      </div>
      <h1 class="text-xl font-bold text-slate-900 dark:text-white break-words"><%= title %></h1>
      <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">
        <% if (owner) { %><span class="badge badge-blue"><i data-lucide="eye" class="w-3 h-3"></i> Owner preview</span> — visitors will see this
        <% } else { %>Files available for download<% } %>
      </p>
    </div>

    <% if (hasVerifyCode && !verified) { %>
    <div id="verify-section" class="bg-slate-50 dark:bg-slate-800/50 rounded-xl p-5 mb-6 border border-slate-100 dark:border-slate-800">
      <div class="flex items-center gap-2 mb-3">
        <i data-lucide="shield-check" class="w-5 h-5 text-brand-500"></i>
        <h3 class="font-semibold text-slate-900 dark:text-white">Verification Required</h3>
      </div>
      <p class="text-sm text-slate-500 dark:text-slate-400 mb-4">Enter the verification code to access files and send messages</p>
      <div class="flex gap-2">
        <input type="text" id="verify-code-input" placeholder="Enter code" autocomplete="off" class="flex-1 px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
        <button onclick="verifyCode()" id="verify-btn" class="flex items-center gap-1.5 bg-gradient-to-r from-brand-600 to-violet-600 text-white px-5 py-2.5 rounded-xl hover:from-brand-700 hover:to-violet-700 font-semibold text-sm btn-scale shadow-glow hover:shadow-glow-lg whitespace-nowrap">
          <i data-lucide="check" class="w-4 h-4"></i> Verify
        </button>
      </div>
      <p id="verify-error" class="text-red-500 text-sm mt-2 hidden"></p>
    </div>
    <% } %>

    <div id="content-section" class="<%= (hasVerifyCode && !verified) ? 'hidden' : '' %>">
      <% if (files.length === 0) { %>
      <div class="text-center py-8">
        <div class="w-14 h-14 mx-auto rounded-2xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center mb-3"><i data-lucide="file-x" class="w-7 h-7 text-slate-300 dark:text-slate-600"></i></div>
        <p class="text-slate-400 dark:text-slate-500 text-sm">No files attached to this QR code</p>
      </div>
      <% } else { %>
      <div class="space-y-2 mb-6">
        <% files.forEach(function(f) { %>
        <div class="flex items-center justify-between bg-slate-50 dark:bg-slate-800/50 rounded-xl px-4 py-3 border border-slate-100 dark:border-slate-800">
          <div class="flex items-center gap-3 min-w-0">
            <div class="w-10 h-10 rounded-lg bg-brand-50 dark:bg-brand-500/10 flex items-center justify-center flex-shrink-0"><i data-lucide="file" class="w-5 h-5 text-brand-500"></i></div>
            <div class="min-w-0">
              <p class="text-sm font-medium text-slate-900 dark:text-white truncate"><%= f.original_name %></p>
              <p class="text-xs text-slate-400 dark:text-slate-500">
                <%= f.original_size > 1048576 ? (f.original_size / 1048576).toFixed(1) + ' MB' : f.original_size > 1024 ? (f.original_size / 1024).toFixed(1) + ' KB' : f.original_size + ' B' %>
              </p>
            </div>
          </div>
          <a href="/d/<%= f.id %>"
             class="flex items-center gap-1.5 bg-brand-600 text-white px-4 py-2 rounded-xl hover:bg-brand-700 text-xs font-medium whitespace-nowrap ml-3 btn-scale download-link transition-all">
            <i data-lucide="download" class="w-3.5 h-3.5"></i> Download
          </a>
        </div>
        <% }); %>
      </div>
      <% } %>

      <div class="section-divider my-6"></div>

      <div id="chat-section">
        <div class="flex items-center gap-2 mb-3">
          <i data-lucide="message-square" class="w-4 h-4 text-slate-400"></i>
          <h3 class="font-semibold text-sm text-slate-900 dark:text-white">Send a Message</h3>
        </div>
        <p class="text-xs text-slate-400 dark:text-slate-500 mb-4">Your message will be delivered to the owner of this QR code</p>

        <div id="chat-messages" class="space-y-3 mb-4 max-h-80 overflow-y-auto bg-slate-50 dark:bg-slate-800/50 rounded-xl p-3 border border-slate-100 dark:border-slate-800">
          <p class="text-xs text-slate-400 dark:text-slate-500 text-center py-2">No messages yet</p>
        </div>

        <div class="flex flex-col sm:flex-row gap-2 mb-2">
          <input type="text" id="chat-name" placeholder="Your name (optional)" maxlength="100" class="sm:w-1/3 px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
          <input type="text" id="chat-input" placeholder="Type your message..." maxlength="2000" class="flex-1 px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow" onkeydown="if(event.key==='Enter')sendMessage()">
          <button onclick="sendMessage()" id="chat-send-btn" class="flex items-center justify-center gap-1.5 bg-brand-600 text-white px-5 py-2.5 rounded-xl hover:bg-brand-700 font-semibold text-sm btn-scale whitespace-nowrap transition-all">
            <i data-lucide="send" class="w-4 h-4"></i> Send
          </button>
        </div>
        <p id="chat-status" class="text-xs text-slate-400 dark:text-slate-500 hidden"></p>
      </div>
    </div>
  </div>
</div>

<div id="toast-container" class="fixed bottom-4 right-4 z-50 space-y-2"></div>

<script>
window.__verifyCode = '';
var qrId = '<%= qrId %>';
var isOwner = <%= owner ? 'true' : 'false' %>;
var hasVerifyCode = <%= hasVerifyCode ? 'true' : 'false' %>;

document.getElementById('chat-input')?.addEventListener('keydown', function(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
});

function verifyCode() {
  var code = document.getElementById('verify-code-input').value.trim();
  if (!code) { showError('verify-error', 'Enter verification code'); return; }
  var btn = document.getElementById('verify-btn');
  btn.disabled = true; btn.textContent = 'Verifying...';
  fetch('/api/verify-code/' + qrId, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ code: code })
  })
  .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, d: d }; }); })
  .then(function(res) {
    if (res.d.valid) {
      window.__verifyCode = code;
      document.getElementById('verify-section').classList.add('hidden');
      document.getElementById('content-section').classList.remove('hidden');
      document.querySelectorAll('.download-link').forEach(function(a) {
        var u = new URL(a.href, window.location.origin);
        u.searchParams.set('code', code);
        a.href = u.toString();
      });
      document.cookie = 'vc_' + qrId + '=1; path=/; max-age=3600; SameSite=Lax';
      showToast('Verified!', 'success');
      loadMessages();
    } else {
      showError('verify-error', res.d.error || 'Invalid code');
      btn.disabled = false; btn.textContent = 'Verify';
    }
  })
  .catch(function() {
    showError('verify-error', 'Verification failed');
    btn.disabled = false; btn.textContent = 'Verify';
  });
}

function sendMessage() {
  var name = document.getElementById('chat-name').value.trim() || 'Anonymous';
  var msg = document.getElementById('chat-input').value.trim();
  if (!msg) return;
  var btn = document.getElementById('chat-send-btn');
  btn.disabled = true; btn.textContent = '...';
  fetch('/api/messages/' + qrId, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ name: name, message: msg })
  })
  .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, d: d }; }); })
  .then(function(res) {
    if (res.ok && res.d.success) {
      document.getElementById('chat-input').value = '';
      addMessage(res.d.message, true);
      showToast('Message sent!', 'success');
    } else {
      showToast(res.d.error || 'Failed to send', 'error');
    }
    btn.disabled = false; btn.textContent = 'Send';
  })
  .catch(function() { btn.disabled = false; btn.textContent = 'Send'; showToast('Network error', 'error'); });
}

function addMessage(msg, isNew) {
  var container = document.getElementById('chat-messages');
  if (container.querySelector('p.text-xs.text-center')) container.innerHTML = '';
  var div = document.createElement('div');
  div.className = 'bg-white dark:bg-slate-900 rounded-xl px-4 py-3 border border-slate-100 dark:border-slate-800' + (isNew ? ' border-brand-300 dark:border-brand-500/30' : '');
  div.innerHTML = '<div class="flex justify-between items-start gap-2"><span class="text-xs font-semibold text-brand-600 dark:text-brand-400">' + escapeHtml(msg.sender_name) + '</span><span class="text-xs text-slate-400 whitespace-nowrap">' + (msg.created_at || 'just now') + '</span></div><p class="text-sm text-slate-900 dark:text-white mt-1.5 break-words">' + escapeHtml(msg.message) + '</p>';
  if (msg.reply) {
    div.innerHTML += '<div class="mt-2.5 pl-3 border-l-2 border-emerald-400 bg-emerald-50 dark:bg-emerald-500/10 rounded-r-lg px-3 py-2"><span class="text-xs font-medium text-emerald-600 dark:text-emerald-400">Owner reply:</span><p class="text-sm text-slate-700 dark:text-slate-300 mt-1 break-words">' + escapeHtml(msg.reply) + '</p></div>';
  }
  container.appendChild(div);
  container.scrollTop = container.scrollHeight;
}

function loadMessages() {
  fetch('/api/messages/' + qrId + '/public')
  .then(function(r) { return r.json(); })
  .then(function(d) {
    if (d.messages && d.messages.length) {
      document.getElementById('chat-messages').innerHTML = '';
      d.messages.forEach(function(m) { addMessage(m, false); });
    }
  }).catch(function() {});
}

function escapeHtml(text) {
  var d = document.createElement('div');
  d.textContent = text || '';
  return d.innerHTML;
}

function showError(id, msg) {
  var el = document.getElementById(id);
  el.textContent = msg;
  el.classList.remove('hidden');
}

function showToast(message, type) {
  var c = document.getElementById('toast-container');
  var t = document.createElement('div');
  t.className = 'toast-enter flex items-center gap-2 px-4 py-3 rounded-xl shadow-lg text-sm font-medium ' + (type === 'error' ? 'bg-red-500 text-white' : 'bg-emerald-500 text-white');
  t.textContent = message;
  c.appendChild(t);
  setTimeout(function() { t.style.opacity = '0'; t.style.transition = 'opacity 0.3s'; setTimeout(function() { t.remove(); }, 300); }, 2500);
}

<% if (verified) { %>
loadMessages();
<% } %>
document.addEventListener('DOMContentLoaded', function() { if (window.lucide) lucide.createIcons(); });
</script>
<%- include('partials/footer') %>
