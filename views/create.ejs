<%- include('partials/header') %>
<div class="max-w-3xl mx-auto fade-in">
  <h1 class="text-2xl font-bold mb-6 dark:text-white">Create QR Code</h1>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-100 dark:bg-red-900 border border-red-400 dark:border-red-700 text-red-700 dark:text-red-300 px-4 py-3 rounded mb-4 text-sm"><%= error %></div>
  <% } %>
  <form method="POST" action="/create" enctype="multipart/form-data" class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border dark:border-gray-700 space-y-6" onsubmit="document.getElementById('submit-btn').disabled=true;document.getElementById('submit-btn').innerHTML='<span class=\\'spinner\\'></span> Creating...'">
    <input type="hidden" name="_csrf" value="<%= typeof _csrf !== 'undefined' ? _csrf : '' %>">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Title</label>
        <input type="text" name="title" placeholder="My QR Code" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Type</label>
        <select name="type" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          <option value="dynamic">Dynamic (editable, with analytics)</option>
          <option value="static">Static (fixed, no analytics)</option>
        </select>
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Content Type</label>
      <select name="content_type" id="content-type" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none" onchange="toggleContentType()">
        <option value="link">URL / Link</option>
        <option value="file">File (PDF, image, etc.)</option>
        <option value="vcard">Business Card (vCard)</option>
        <option value="text">Text / Data</option>
      </select>
    </div>

    <div id="link-field">
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Target URL</label>
      <input type="url" name="target_url" placeholder="https://example.com" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
    </div>

    <div id="file-field" class="hidden">
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Upload File</label>
      <input type="file" name="file" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
      <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Max 50 MB. Supported: PDF, images, audio, documents</p>
    </div>

    <div id="vcard-field" class="hidden">
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">vCard Data</label>
      <textarea name="vcard_data" rows="6" placeholder="BEGIN:VCARD&#10;VERSION:3.0&#10;FN:John Doe&#10;EMAIL:john@example.com&#10;TEL:+1234567890&#10;END:VCARD" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white font-mono text-xs focus:ring-2 focus:ring-indigo-500 focus:outline-none"></textarea>
    </div>

    <div id="text-field" class="hidden">
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Text Content</label>
      <textarea name="text_data" rows="4" placeholder="Enter text content..." class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none"></textarea>
    </div>

    <hr class="border-gray-200 dark:border-gray-600">

    <h3 class="font-semibold text-gray-700 dark:text-gray-300">Design</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Foreground Color</label>
        <input type="color" name="fg_color" value="#000000" class="w-full h-10 border dark:border-gray-600 rounded-lg cursor-pointer">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Background Color</label>
        <input type="color" name="bg_color" value="#FFFFFF" class="w-full h-10 border dark:border-gray-600 rounded-lg cursor-pointer">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Dot Style</label>
        <select name="dot_style" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          <option value="square">Square</option>
          <option value="rounded">Rounded</option>
          <option value="circle">Circle</option>
        </select>
      </div>
    </div>

    <hr class="border-gray-200 dark:border-gray-600">

    <h3 class="font-semibold text-gray-700 dark:text-gray-300">Access Control (optional)</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Password Protection</label>
        <input type="text" name="password" placeholder="Leave empty for public" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Expires At</label>
        <input type="datetime-local" name="expires_at" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Scan Limit</label>
        <input type="number" name="scan_limit" min="0" placeholder="Unlimited" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
      </div>
    </div>

    <button id="submit-btn" type="submit" class="w-full bg-indigo-600 text-white py-3 rounded-lg hover:bg-indigo-700 font-medium transition-colors">Generate QR Code</button>
  </form>
</div>

<script>
function toggleContentType() {
  const v = document.getElementById('content-type').value;
  document.getElementById('link-field').classList.toggle('hidden', v !== 'link');
  document.getElementById('file-field').classList.toggle('hidden', v !== 'file');
  document.getElementById('vcard-field').classList.toggle('hidden', v !== 'vcard');
  document.getElementById('text-field').classList.toggle('hidden', v !== 'text');
}
toggleContentType();
</script>
<%- include('partials/footer') %>
