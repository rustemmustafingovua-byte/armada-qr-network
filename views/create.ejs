<%- include('partials/header') %>
<div class="max-w-5xl mx-auto fade-in">
  <h1 class="text-2xl font-bold mb-6 dark:text-white">Create QR Code</h1>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-100 dark:bg-red-900 border border-red-400 dark:border-red-700 text-red-700 dark:text-red-300 px-4 py-3 rounded mb-4 text-sm"><%= error %></div>
  <% } %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <form method="POST" action="/create" enctype="multipart/form-data" class="lg:col-span-2 bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border dark:border-gray-700 space-y-6" id="create-form" onsubmit="document.getElementById('submit-btn').disabled=true;document.getElementById('submit-btn').innerHTML='<span class=\\'spinner\\'></span> Creating...'">
      <input type="hidden" name="_csrf" value="<%= typeof _csrf !== 'undefined' ? _csrf : '' %>">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Title *</label>
          <input type="text" name="title" required maxlength="200" placeholder="My QR Code" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Type</label>
          <select name="type" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
            <option value="dynamic">Dynamic (editable, with analytics)</option>
            <option value="static">Static (fixed, no analytics)</option>
          </select>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Content Type</label>
        <div class="grid grid-cols-3 sm:grid-cols-6 gap-2" role="radiogroup">
          <label class="cursor-pointer"><input type="radio" name="content_type_radio" value="link" checked class="peer sr-only" onchange="setContentType('link')"><div class="text-center p-3 border-2 dark:border-gray-600 rounded-lg peer-checked:border-indigo-500 peer-checked:bg-indigo-50 dark:peer-checked:bg-indigo-900/30 transition-colors"><div class="text-2xl">🔗</div><div class="text-xs mt-1 dark:text-gray-300">URL</div></div></label>
          <label class="cursor-pointer"><input type="radio" name="content_type_radio" value="file" class="peer sr-only" onchange="setContentType('file')"><div class="text-center p-3 border-2 dark:border-gray-600 rounded-lg peer-checked:border-indigo-500 peer-checked:bg-indigo-50 dark:peer-checked:bg-indigo-900/30 transition-colors"><div class="text-2xl">📁</div><div class="text-xs mt-1 dark:text-gray-300">File</div></div></label>
          <label class="cursor-pointer"><input type="radio" name="content_type_radio" value="vcard" class="peer sr-only" onchange="setContentType('vcard')"><div class="text-center p-3 border-2 dark:border-gray-600 rounded-lg peer-checked:border-indigo-500 peer-checked:bg-indigo-50 dark:peer-checked:bg-indigo-900/30 transition-colors"><div class="text-2xl">👤</div><div class="text-xs mt-1 dark:text-gray-300">vCard</div></div></label>
          <label class="cursor-pointer"><input type="radio" name="content_type_radio" value="text" class="peer sr-only" onchange="setContentType('text')"><div class="text-center p-3 border-2 dark:border-gray-600 rounded-lg peer-checked:border-indigo-500 peer-checked:bg-indigo-50 dark:peer-checked:bg-indigo-900/30 transition-colors"><div class="text-2xl">📝</div><div class="text-xs mt-1 dark:text-gray-300">Text</div></div></label>
          <label class="cursor-pointer"><input type="radio" name="content_type_radio" value="wifi" class="peer sr-only" onchange="setContentType('wifi')"><div class="text-center p-3 border-2 dark:border-gray-600 rounded-lg peer-checked:border-indigo-500 peer-checked:bg-indigo-50 dark:peer-checked:bg-indigo-900/30 transition-colors"><div class="text-2xl">📶</div><div class="text-xs mt-1 dark:text-gray-300">WiFi</div></div></label>
          <label class="cursor-pointer"><input type="radio" name="content_type_radio" value="event" class="peer sr-only" onchange="setContentType('event')"><div class="text-center p-3 border-2 dark:border-gray-600 rounded-lg peer-checked:border-indigo-500 peer-checked:bg-indigo-50 dark:peer-checked:bg-indigo-900/30 transition-colors"><div class="text-2xl">📅</div><div class="text-xs mt-1 dark:text-gray-300">Event</div></div></label>
        </div>
        <input type="hidden" name="content_type" id="content-type" value="link">
      </div>

      <div id="link-field" class="content-field">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Target URL *</label>
        <input type="url" name="target_url" placeholder="https://example.com" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
      </div>

      <div id="file-field" class="content-field hidden">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Upload File *</label>
        <div id="drop-zone" class="border-2 border-dashed dark:border-gray-600 rounded-lg p-6 text-center cursor-pointer hover:border-indigo-400 dark:hover:border-indigo-500 transition-colors">
          <input type="file" name="file" id="file-input" class="hidden">
          <div class="text-4xl mb-2">📤</div>
          <p class="text-sm text-gray-600 dark:text-gray-400"><span class="text-indigo-600 dark:text-indigo-400 font-medium">Click to upload</span> or drag & drop</p>
          <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Max 200 MB — auto-compressed, any format</p>
          <p id="file-name" class="text-sm font-medium text-indigo-600 dark:text-indigo-400 mt-2 hidden"></p>
          <div id="upload-progress" class="hidden mt-2 w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2 overflow-hidden">
            <div id="upload-bar" class="bg-indigo-600 h-2 transition-all duration-200" style="width:0%"></div>
          </div>
        </div>
      </div>

      <div id="vcard-field" class="content-field hidden">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">vCard Data *</label>
        <textarea name="vcard_data" rows="6" placeholder="BEGIN:VCARD&#10;VERSION:3.0&#10;FN:John Doe&#10;EMAIL:john@example.com&#10;TEL:+1234567890&#10;ORG:Company&#10;URL:https://example.com&#10;END:VCARD" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white font-mono text-xs focus:ring-2 focus:ring-indigo-500 focus:outline-none"></textarea>
        <button type="button" onclick="document.getElementById('vcard-builder').classList.toggle('hidden')" class="mt-1 text-xs text-indigo-600 dark:text-indigo-400 hover:underline">📇 Use visual builder</button>
        <div id="vcard-builder" class="hidden mt-2 p-3 bg-gray-50 dark:bg-gray-900 rounded-lg space-y-2">
          <input data-vcard="FN" placeholder="Full Name" class="w-full px-2 py-1 text-sm border dark:border-gray-600 rounded bg-white dark:bg-gray-700 dark:text-white">
          <input data-vcard="ORG" placeholder="Organization" class="w-full px-2 py-1 text-sm border dark:border-gray-600 rounded bg-white dark:bg-gray-700 dark:text-white">
          <input data-vcard="TITLE" placeholder="Job Title" class="w-full px-2 py-1 text-sm border dark:border-gray-600 rounded bg-white dark:bg-gray-700 dark:text-white">
          <input data-vcard="EMAIL" placeholder="Email" class="w-full px-2 py-1 text-sm border dark:border-gray-600 rounded bg-white dark:bg-gray-700 dark:text-white">
          <input data-vcard="TEL" placeholder="Phone" class="w-full px-2 py-1 text-sm border dark:border-gray-600 rounded bg-white dark:bg-gray-700 dark:text-white">
          <input data-vcard="URL" placeholder="Website" class="w-full px-2 py-1 text-sm border dark:border-gray-600 rounded bg-white dark:bg-gray-700 dark:text-white">
          <button type="button" onclick="buildVcard()" class="text-xs bg-indigo-600 text-white px-3 py-1 rounded">Generate</button>
        </div>
      </div>

      <div id="text-field" class="content-field hidden">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Text Content *</label>
        <textarea name="text_data" rows="4" placeholder="Enter any text content..." maxlength="5000" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none"></textarea>
        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1"><span id="text-count">0</span>/5000</p>
      </div>

      <div id="wifi-field" class="content-field hidden space-y-3">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Network Name (SSID) *</label>
          <input type="text" name="wifi_ssid" placeholder="MyWiFi" maxlength="100" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Password</label>
          <input type="text" name="wifi_password" placeholder="password" maxlength="200" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Encryption</label>
            <select name="wifi_encryption" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
              <option value="WPA">WPA/WPA2</option>
              <option value="WEP">WEP</option>
              <option value="nopass">None (open)</option>
            </select>
          </div>
          <div class="flex items-end">
            <label class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
              <input type="checkbox" name="wifi_hidden" class="rounded border-gray-300 dark:border-gray-600">
              Hidden network
            </label>
          </div>
        </div>
      </div>

      <div id="event-field" class="content-field hidden space-y-3">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Event Title *</label>
          <input type="text" name="event_title" placeholder="Team Meeting" maxlength="200" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Location</label>
          <input type="text" name="event_location" placeholder="Conference Room A" maxlength="300" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Start</label>
            <input type="datetime-local" name="event_start" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">End</label>
            <input type="datetime-local" name="event_end" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Description</label>
          <textarea name="event_description" rows="3" maxlength="2000" placeholder="Meeting agenda and notes..." class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none"></textarea>
        </div>
      </div>

      <hr class="border-gray-200 dark:border-gray-600">
      <h3 class="font-semibold text-gray-700 dark:text-gray-300">Design</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Foreground Color</label>
          <input type="color" name="fg_color" value="#000000" class="w-full h-10 border dark:border-gray-600 rounded-lg cursor-pointer">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Background Color</label>
          <input type="color" name="bg_color" value="#FFFFFF" class="w-full h-10 border dark:border-gray-600 rounded-lg cursor-pointer">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Style</label>
          <select name="dot_style" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
            <option value="square">Square</option>
            <option value="rounded">Rounded</option>
            <option value="circle">Dots</option>
          </select>
        </div>
      </div>

      <hr class="border-gray-200 dark:border-gray-600">
      <details class="space-y-4">
        <summary class="font-semibold text-gray-700 dark:text-gray-300 cursor-pointer">Access Control (optional)</summary>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Password Protection</label>
            <input type="text" name="password" placeholder="Leave empty for public" maxlength="128" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Verification Code <span class="text-gray-400 text-xs">(for files only)</span></label>
            <input type="text" name="verify_code" placeholder="Code to download files" maxlength="128" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Expires At</label>
            <input type="datetime-local" name="expires_at" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Scan Limit</label>
            <input type="number" name="scan_limit" min="0" max="9999999" placeholder="Unlimited" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tags <span class="text-gray-400 text-xs">(comma-separated)</span></label>
            <input type="text" name="tags" placeholder="marketing, campaign-2026, urgent" maxlength="500" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          </div>
        </div>
      </details>

      <details class="space-y-4">
        <summary class="font-semibold text-gray-700 dark:text-gray-300 cursor-pointer">Advanced</summary>
        <div class="mt-3 space-y-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Webhook URL <span class="text-gray-400 text-xs">(notified on scan)</span></label>
            <input type="url" name="webhook_url" placeholder="https://your-api.com/webhook" maxlength="500" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Internal Notes</label>
            <textarea name="notes" rows="2" maxlength="2000" placeholder="Notes for your reference (not visible to scanners)..." class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none"></textarea>
          </div>
        </div>
      </details>

      <button id="submit-btn" type="submit" class="w-full bg-indigo-600 text-white py-3 rounded-lg hover:bg-indigo-700 font-medium transition-colors">Generate QR Code</button>
    </form>

    <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border dark:border-gray-700 h-fit sticky top-20">
      <h3 class="font-semibold text-gray-700 dark:text-gray-300 mb-3">Live Preview</h3>
      <div id="preview-container" class="bg-gray-50 dark:bg-gray-900 rounded-lg p-4 mb-3 flex items-center justify-center min-h-[200px]">
        <div class="text-center text-gray-400 dark:text-gray-500 text-sm">
          <div class="text-4xl mb-2">📱</div>
          Preview will appear here
        </div>
      </div>
      <p class="text-xs text-gray-400 dark:text-gray-500 text-center">QR generated server-side on submit. Colors update live below.</p>
      <div class="grid grid-cols-2 gap-2 mt-3">
        <div class="bg-gray-50 dark:bg-gray-900 p-2 rounded text-center">
          <p class="text-[10px] uppercase text-gray-400">Foreground</p>
          <p class="font-mono text-xs dark:text-white" id="fg-preview">#000000</p>
        </div>
        <div class="bg-gray-50 dark:bg-gray-900 p-2 rounded text-center">
          <p class="text-[10px] uppercase text-gray-400">Background</p>
          <p class="font-mono text-xs dark:text-white" id="bg-preview">#FFFFFF</p>
        </div>
      </div>
    </div>
  </div>
</div>

<div id="toast-container" class="fixed bottom-4 right-4 z-50 space-y-2"></div>

<script>
function setContentType(t) {
  document.getElementById('content-type').value = t;
  document.querySelectorAll('.content-field').forEach(function(el) { el.classList.add('hidden'); });
  var map = { link: 'link-field', file: 'file-field', vcard: 'vcard-field', text: 'text-field', wifi: 'wifi-field', event: 'event-field' };
  var target = document.getElementById(map[t]);
  if (target) target.classList.remove('hidden');
}

document.querySelectorAll('input[name="content_type_radio"]').forEach(function(r) {
  r.addEventListener('change', function() { setContentType(this.value); });
});

var dropZone = document.getElementById('drop-zone');
var fileInput = document.getElementById('file-input');
if (dropZone) {
  dropZone.addEventListener('click', function() { fileInput.click(); });
  fileInput.addEventListener('change', function() { showFile(this.files[0]); });
  ['dragenter', 'dragover'].forEach(function(e) { dropZone.addEventListener(e, function(ev) { ev.preventDefault(); ev.stopPropagation(); dropZone.classList.add('border-indigo-500', 'bg-indigo-50', 'dark:bg-indigo-900/20'); }); });
  ['dragleave', 'drop'].forEach(function(e) { dropZone.addEventListener(e, function(ev) { ev.preventDefault(); ev.stopPropagation(); dropZone.classList.remove('border-indigo-500', 'bg-indigo-50', 'dark:bg-indigo-900/20'); }); });
  dropZone.addEventListener('drop', function(ev) { if (ev.dataTransfer.files.length) { fileInput.files = ev.dataTransfer.files; showFile(ev.dataTransfer.files[0]); } });
}
function showFile(f) {
  if (!f) return;
  var el = document.getElementById('file-name');
  el.textContent = '📄 ' + f.name + ' (' + (f.size / 1024).toFixed(1) + ' KB)';
  el.classList.remove('hidden');
}

var textArea = document.querySelector('textarea[name="text_data"]');
if (textArea) {
  textArea.addEventListener('input', function() { document.getElementById('text-count').textContent = this.value.length; });
}

function buildVcard() {
  var parts = ['BEGIN:VCARD', 'VERSION:3.0'];
  document.querySelectorAll('#vcard-builder input[data-vcard]').forEach(function(inp) {
    var v = inp.value.trim();
    if (v) parts.push(inp.dataset.vcard + ':' + v);
  });
  parts.push('END:VCARD');
  document.querySelector('textarea[name="vcard_data"]').value = parts.join('\n');
}

document.querySelector('input[name="fg_color"]').addEventListener('input', function() { document.getElementById('fg-preview').textContent = this.value; });
document.querySelector('input[name="bg_color"]').addEventListener('input', function() { document.getElementById('bg-preview').textContent = this.value; });

function showToast(message, type) {
  var c = document.getElementById('toast-container');
  var t = document.createElement('div');
  t.className = 'px-4 py-2 rounded-lg shadow-lg text-sm font-medium ' + (type === 'error' ? 'bg-red-600 text-white' : 'bg-green-600 text-white');
  t.textContent = message;
  c.appendChild(t);
  setTimeout(function() { t.style.opacity = '0'; t.style.transition = 'opacity 0.3s'; setTimeout(function() { t.remove(); }, 300); }, 2500);
}
</script>
<%- include('partials/footer') %>
