<%- include('partials/header') %>
<div class="max-w-3xl mx-auto fade-in">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold dark:text-white">Edit QR Code</h1>
    <a href="/dashboard" class="text-indigo-600 dark:text-indigo-400 hover:underline text-sm">← Back to Dashboard</a>
  </div>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-100 dark:bg-red-900 border border-red-400 dark:border-red-700 text-red-700 dark:text-red-300 px-4 py-3 rounded mb-4 text-sm"><%= error %></div>
  <% } %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <form method="POST" enctype="multipart/form-data" class="lg:col-span-2 bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border dark:border-gray-700 space-y-6" onsubmit="document.getElementById('save-btn').disabled=true;document.getElementById('save-btn').innerHTML='<span class=\\'spinner\\'></span> Saving...'">
      <input type="hidden" name="_csrf" value="<%= _csrf %>">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Title</label>
        <input type="text" name="title" value="<%= qr.title %>" required maxlength="200" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Content Type</label>
        <p class="text-gray-500 dark:text-gray-400 text-sm bg-gray-50 dark:bg-gray-900 px-3 py-2 rounded border dark:border-gray-600"><span class="font-mono"><%= qr.content_type %></span> — cannot be changed</p>
      </div>

      <% if (qr.content_type === 'link') { %>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Target URL</label>
        <input type="url" name="target_url" value="<%= qr.target_url %>" required class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
      </div>
      <% } %>

      <% if (qr.content_type === 'file') { %>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Current File</label>
        <p class="text-gray-500 dark:text-gray-400 text-sm mb-2"><%= qr.file_name || 'No file uploaded' %></p>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Replace with New File</label>
        <input type="file" name="file" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Optional — leave empty to keep current file</p>
      </div>
      <% } %>

      <% if (qr.content_type === 'vcard') { %>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">vCard Data</label>
        <textarea name="vcard_data" rows="6" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white font-mono text-xs focus:ring-2 focus:ring-indigo-500 focus:outline-none"><%= qr.vcard_data %></textarea>
      </div>
      <% } %>

      <% if (qr.content_type === 'text') { %>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Text Content</label>
        <textarea name="text_data" rows="4" maxlength="5000" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none"><%= qr.text_data %></textarea>
      </div>
      <% } %>

      <% if (qr.content_type === 'wifi') { %>
      <div class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">SSID</label>
          <input type="text" name="wifi_ssid" value="<%= qr.wifi_ssid %>" maxlength="100" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Password</label>
          <input type="text" name="wifi_password" value="<%= qr.wifi_password %>" maxlength="200" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Encryption</label>
            <select name="wifi_encryption" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
              <option value="WPA" <%= qr.wifi_encryption === 'WPA' ? 'selected' : '' %>>WPA/WPA2</option>
              <option value="WEP" <%= qr.wifi_encryption === 'WEP' ? 'selected' : '' %>>WEP</option>
              <option value="nopass" <%= qr.wifi_encryption === 'nopass' ? 'selected' : '' %>>None</option>
            </select>
          </div>
          <div class="flex items-end">
            <label class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
              <input type="checkbox" name="wifi_hidden" <%= qr.wifi_hidden ? 'checked' : '' %> class="rounded border-gray-300 dark:border-gray-600">
              Hidden
            </label>
          </div>
        </div>
      </div>
      <% } %>

      <% if (qr.content_type === 'event') { %>
      <div class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Title</label>
          <input type="text" name="event_title" value="<%= qr.event_title %>" maxlength="200" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Location</label>
          <input type="text" name="event_location" value="<%= qr.event_location %>" maxlength="300" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Start</label>
            <input type="datetime-local" name="event_start" value="<%= qr.event_start ? qr.event_start.substring(0, 16) : '' %>" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">End</label>
            <input type="datetime-local" name="event_end" value="<%= qr.event_end ? qr.event_end.substring(0, 16) : '' %>" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Description</label>
          <textarea name="event_description" rows="3" maxlength="2000" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none"><%= qr.event_description %></textarea>
        </div>
      </div>
      <% } %>

      <hr class="border-gray-200 dark:border-gray-600">
      <h3 class="font-semibold text-gray-700 dark:text-gray-300">Design</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Foreground</label>
          <input type="color" name="fg_color" value="<%= qr.fg_color %>" class="w-full h-10 border dark:border-gray-600 rounded-lg cursor-pointer">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Background</label>
          <input type="color" name="bg_color" value="<%= qr.bg_color %>" class="w-full h-10 border dark:border-gray-600 rounded-lg cursor-pointer">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Style</label>
          <select name="dot_style" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
            <option value="square" <%= qr.dot_style === 'square' ? 'selected' : '' %>>Square</option>
            <option value="rounded" <%= qr.dot_style === 'rounded' ? 'selected' : '' %>>Rounded</option>
            <option value="circle" <%= qr.dot_style === 'circle' ? 'selected' : '' %>>Dots</option>
          </select>
        </div>
      </div>

      <hr class="border-gray-200 dark:border-gray-600">
      <h3 class="font-semibold text-gray-700 dark:text-gray-300">Access Control</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">New Password <span class="text-gray-400 dark:text-gray-500 font-normal text-xs">(leave blank to keep)</span></label>
          <input type="text" name="password" placeholder="••••••" maxlength="128" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          <% if (qr.password_hash) { %>
            <label class="flex items-center gap-1 mt-1 text-xs text-gray-500 dark:text-gray-400">
              <input type="checkbox" name="password_clear" value="__clear__" form="password-form" class="rounded"> Remove password
            </label>
          <% } %>
        </div>
        <% if (qr.content_type === 'file') { %>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Verification Code <span class="text-gray-400 dark:text-gray-500 font-normal text-xs">(leave blank to keep)</span></label>
          <input type="text" name="verify_code" placeholder="New code" maxlength="128" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
        <% } %>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Expires At</label>
          <input type="datetime-local" name="expires_at" value="<%= qr.expires_at ? qr.expires_at.substring(0, 16) : '' %>" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Scan Limit</label>
          <input type="number" name="scan_limit" min="0" max="9999999" value="<%= qr.scan_limit || '' %>" placeholder="Unlimited" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tags <span class="text-gray-400 text-xs">(comma-separated)</span></label>
          <input type="text" name="tags" value="<%= qr.tags || '' %>" maxlength="500" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Internal Notes</label>
          <textarea name="notes" rows="2" maxlength="2000" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none"><%= qr.notes || '' %></textarea>
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Webhook URL <span class="text-gray-400 text-xs">(notified on scan)</span></label>
          <input type="url" name="webhook_url" value="<%= qr.webhook_url || '' %>" maxlength="500" placeholder="https://your-api.com/webhook" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none">
        </div>
      </div>

      <div class="flex items-center gap-2">
        <input type="checkbox" name="is_active" value="1" <%= qr.is_active ? 'checked' : '' %> class="rounded border-gray-300 dark:border-gray-600">
        <label class="text-sm font-medium text-gray-700 dark:text-gray-300">Active <span class="text-gray-400 text-xs">(uncheck to deactivate without deleting)</span></label>
      </div>

      <button id="save-btn" type="submit" class="w-full bg-indigo-600 text-white py-3 rounded-lg hover:bg-indigo-700 font-medium transition-colors">Save Changes</button>
    </form>

    <div class="bg-white dark:bg-gray-800 p-4 rounded-xl shadow-sm border dark:border-gray-700 h-fit">
      <h3 class="font-semibold text-sm text-gray-600 dark:text-gray-400 mb-3">Current QR</h3>
      <img src="/qr-image-public/<%= qr.id %>" alt="QR" class="w-full border dark:border-gray-700 rounded p-2 bg-white" id="qr-preview">
      <div class="mt-3 space-y-1 text-xs">
        <p class="text-gray-500 dark:text-gray-400">Scans: <span class="font-mono font-bold dark:text-white"><%= qr.scan_count %></span></p>
        <p class="text-gray-500 dark:text-gray-400">Status: <span class="<%= qr.is_active ? 'text-green-600' : 'text-red-500' %>"><%= qr.is_active ? '● Active' : '● Inactive' %></span></p>
        <p class="text-gray-500 dark:text-gray-400">Created: <%= qr.created_at %></p>
      </div>
      <div class="grid grid-cols-2 gap-2 mt-3">
        <a href="/qr-svg/<%= qr.id %>" class="text-center text-xs bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 py-1.5 rounded hover:bg-gray-200 dark:hover:bg-gray-600">SVG</a>
        <a href="/qr-png/<%= qr.id %>" class="text-center text-xs bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 py-1.5 rounded hover:bg-gray-200 dark:hover:bg-gray-600">PNG</a>
      </div>
      <a href="/analytics/<%= qr.id %>" class="block text-center text-xs bg-indigo-600 text-white py-1.5 rounded hover:bg-indigo-700 mt-2">View Analytics</a>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
