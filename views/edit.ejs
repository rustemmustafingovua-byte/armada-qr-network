<%- include('partials/header') %>
<div class="max-w-3xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Edit QR Code</h1>
    <a href="/dashboard" class="text-indigo-600 hover:underline text-sm">Back to Dashboard</a>
  </div>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4 text-sm"><%= error %></div>
  <% } %>
  <form method="POST" enctype="multipart/form-data" class="bg-white p-6 rounded-xl shadow-sm border space-y-6">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
      <input type="text" name="title" value="<%= qr.title %>" class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500 focus:outline-none">
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Content Type</label>
      <p class="text-gray-500 text-sm bg-gray-50 px-3 py-2 rounded border"><%= qr.content_type %></p>
      <p class="text-xs text-gray-400 mt-1">Content type cannot be changed after creation</p>
    </div>

    <% if (qr.content_type === 'link') { %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Target URL</label>
      <input type="url" name="target_url" value="<%= qr.target_url %>" class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500 focus:outline-none">
    </div>
    <% } %>

    <% if (qr.content_type === 'file') { %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Current File</label>
      <p class="text-gray-500 text-sm mb-2"><%= qr.file_name || 'No file uploaded' %></p>
      <label class="block text-sm font-medium text-gray-700 mb-1">Upload New File</label>
      <input type="file" name="file" class="w-full px-3 py-2 border rounded-lg">
    </div>
    <% } %>

    <% if (qr.content_type === 'vcard') { %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">vCard Data</label>
      <textarea name="vcard_data" rows="6" class="w-full px-3 py-2 border rounded-lg font-mono text-xs"><%= qr.vcard_data %></textarea>
    </div>
    <% } %>

    <% if (qr.content_type === 'text') { %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Text Content</label>
      <textarea name="text_data" rows="4" class="w-full px-3 py-2 border rounded-lg"><%= qr.text_data %></textarea>
    </div>
    <% } %>

    <hr class="border-gray-200">

    <h3 class="font-semibold text-gray-700">Design</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Foreground Color</label>
        <input type="color" name="fg_color" value="<%= qr.fg_color %>" class="w-full h-10 border rounded-lg cursor-pointer">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Background Color</label>
        <input type="color" name="bg_color" value="<%= qr.bg_color %>" class="w-full h-10 border rounded-lg cursor-pointer">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Dot Style</label>
        <select name="dot_style" class="w-full px-3 py-2 border rounded-lg">
          <option value="square" <%= qr.dot_style === 'square' ? 'selected' : '' %>>Square</option>
          <option value="rounded" <%= qr.dot_style === 'rounded' ? 'selected' : '' %>>Rounded</option>
          <option value="circle" <%= qr.dot_style === 'circle' ? 'selected' : '' %>>Circle</option>
        </select>
      </div>
    </div>

    <hr class="border-gray-200">

    <h3 class="font-semibold text-gray-700">Access Control</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">New Password <span class="text-gray-400 font-normal">(leave blank to keep)</span></label>
        <input type="text" name="password" placeholder="Change password" class="w-full px-3 py-2 border rounded-lg">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Expires At</label>
        <input type="datetime-local" name="expires_at" value="<%= qr.expires_at ? qr.expires_at.substring(0, 16) : '' %>" class="w-full px-3 py-2 border rounded-lg">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Scan Limit</label>
        <input type="number" name="scan_limit" min="0" value="<%= qr.scan_limit || '' %>" placeholder="Unlimited" class="w-full px-3 py-2 border rounded-lg">
      </div>
    </div>

    <div class="flex items-center gap-2">
      <input type="checkbox" name="is_active" value="1" <%= qr.is_active ? 'checked' : '' %> class="rounded border-gray-300">
      <label class="text-sm font-medium text-gray-700">Active</label>
    </div>

    <button type="submit" class="w-full bg-indigo-600 text-white py-3 rounded-lg hover:bg-indigo-700 font-medium">Save Changes</button>
  </form>
</div>
<%- include('partials/footer') %>
