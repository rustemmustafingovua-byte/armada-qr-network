<%- include('partials/header') %>
<div class="max-w-3xl mx-auto fade-in">
  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Edit QR Code</h1>
      <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Update your QR code settings and content</p>
    </div>
    <a href="/dashboard" class="flex items-center gap-1.5 text-sm font-medium text-slate-500 hover:text-brand-600 dark:text-slate-400 dark:hover:text-brand-400 transition-colors">
      <i data-lucide="arrow-left" class="w-4 h-4"></i>
      Back to Dashboard
    </a>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="flex items-center gap-2 bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 text-red-700 dark:text-red-400 px-4 py-3 rounded-xl mb-6 text-sm slide-down">
      <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i>
      <span><%= error %></span>
    </div>
  <% } %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <form method="POST" enctype="multipart/form-data" class="lg:col-span-2 space-y-6" onsubmit="document.getElementById('save-btn').disabled=true;document.getElementById('save-btn').innerHTML='<span class=\\'spinner\\'></span> Saving...'">
      <input type="hidden" name="_csrf" value="<%= _csrf %>">

      <!-- Basic Info -->
      <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 shadow-card border border-slate-200/60 dark:border-slate-800/60">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-9 h-9 rounded-xl bg-brand-50 dark:bg-brand-500/10 flex items-center justify-center">
            <i data-lucide="info" class="w-4 h-4 text-brand-600 dark:text-brand-400"></i>
          </div>
          <h2 class="font-semibold text-slate-900 dark:text-white">Basic Info</h2>
        </div>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Title</label>
            <input type="text" name="title" value="<%= qr.title %>" required maxlength="200" class="w-full px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Content Type</label>
            <div class="flex items-center gap-2 px-4 py-2.5 bg-slate-50 dark:bg-slate-800/50 rounded-xl border border-slate-200 dark:border-slate-700">
              <i data-lucide="layers" class="w-4 h-4 text-slate-400"></i>
              <span class="text-sm font-mono text-slate-600 dark:text-slate-300"><%= qr.content_type %></span>
              <span class="text-xs text-slate-400 dark:text-slate-500 ml-auto">cannot be changed</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Content -->
      <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 shadow-card border border-slate-200/60 dark:border-slate-800/60">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-9 h-9 rounded-xl bg-cyan-50 dark:bg-cyan-500/10 flex items-center justify-center">
            <i data-lucide="file-input" class="w-4 h-4 text-cyan-600 dark:text-cyan-400"></i>
          </div>
          <h2 class="font-semibold text-slate-900 dark:text-white">Content</h2>
        </div>

        <% if (qr.content_type === 'link') { %>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Target URL</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i data-lucide="globe" class="w-4 h-4 text-slate-400"></i></div>
            <input type="url" name="target_url" value="<%= qr.target_url %>" required class="w-full pl-10 pr-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
          </div>
        </div>
        <% } %>

        <% if (qr.content_type === 'file') { %>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Current File</label>
            <div class="flex items-center gap-3 px-4 py-3 bg-slate-50 dark:bg-slate-800/50 rounded-xl border border-slate-200 dark:border-slate-700">
              <div class="w-10 h-10 rounded-lg bg-brand-50 dark:bg-brand-500/10 flex items-center justify-center"><i data-lucide="file" class="w-5 h-5 text-brand-500"></i></div>
              <span class="text-sm text-slate-600 dark:text-slate-300"><%= qr.file_name || 'No file uploaded' %></span>
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Replace with New File</label>
            <input type="file" name="file" class="w-full px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:outline-none transition-all file:mr-4 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-brand-50 file:text-brand-600 dark:file:bg-brand-500/10 dark:file:text-brand-400">
            <p class="text-xs text-slate-400 dark:text-slate-500 mt-1.5">Optional — leave empty to keep current file</p>
          </div>
        </div>
        <% } %>

        <% if (qr.content_type === 'vcard') { %>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">vCard Data</label>
          <textarea name="vcard_data" rows="6" class="w-full px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white font-mono text-xs focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow"><%= qr.vcard_data %></textarea>
        </div>
        <% } %>

        <% if (qr.content_type === 'text') { %>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Text Content</label>
          <textarea name="text_data" rows="4" maxlength="5000" class="w-full px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow"><%= qr.text_data %></textarea>
        </div>
        <% } %>

        <% if (qr.content_type === 'wifi') { %>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">SSID</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i data-lucide="wifi" class="w-4 h-4 text-slate-400"></i></div>
              <input type="text" name="wifi_ssid" value="<%= qr.wifi_ssid %>" maxlength="100" class="w-full pl-10 pr-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Password</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i data-lucide="lock" class="w-4 h-4 text-slate-400"></i></div>
              <input type="text" name="wifi_password" value="<%= qr.wifi_password %>" maxlength="200" class="w-full pl-10 pr-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Encryption</label>
              <select name="wifi_encryption" class="w-full px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all">
                <option value="WPA" <%= qr.wifi_encryption === 'WPA' ? 'selected' : '' %>>WPA/WPA2</option>
                <option value="WEP" <%= qr.wifi_encryption === 'WEP' ? 'selected' : '' %>>WEP</option>
                <option value="nopass" <%= qr.wifi_encryption === 'nopass' ? 'selected' : '' %>>None</option>
              </select>
            </div>
            <div class="flex items-end">
              <label class="flex items-center gap-2.5 text-sm text-slate-700 dark:text-slate-300 cursor-pointer">
                <input type="checkbox" name="wifi_hidden" <%= qr.wifi_hidden ? 'checked' : '' %> class="rounded-lg border-slate-300 dark:border-slate-600 text-brand-600 focus:ring-brand-500/30">
                Hidden
              </label>
            </div>
          </div>
        </div>
        <% } %>

        <% if (qr.content_type === 'event') { %>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Title</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i data-lucide="calendar" class="w-4 h-4 text-slate-400"></i></div>
              <input type="text" name="event_title" value="<%= qr.event_title %>" maxlength="200" class="w-full pl-10 pr-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Location</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i data-lucide="map-pin" class="w-4 h-4 text-slate-400"></i></div>
              <input type="text" name="event_location" value="<%= qr.event_location %>" maxlength="300" class="w-full pl-10 pr-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Start</label>
              <input type="datetime-local" name="event_start" value="<%= qr.event_start ? qr.event_start.substring(0, 16) : '' %>" class="w-full px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all">
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">End</label>
              <input type="datetime-local" name="event_end" value="<%= qr.event_end ? qr.event_end.substring(0, 16) : '' %>" class="w-full px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all">
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Description</label>
            <textarea name="event_description" rows="3" maxlength="2000" class="w-full px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow"><%= qr.event_description %></textarea>
          </div>
        </div>
        <% } %>
      </div>

      <!-- Design -->
      <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 shadow-card border border-slate-200/60 dark:border-slate-800/60">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-9 h-9 rounded-xl bg-emerald-50 dark:bg-emerald-500/10 flex items-center justify-center">
            <i data-lucide="palette" class="w-4 h-4 text-emerald-600 dark:text-emerald-400"></i>
          </div>
          <h2 class="font-semibold text-slate-900 dark:text-white">Design</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Foreground</label>
            <input type="color" name="fg_color" value="<%= qr.fg_color %>" class="w-full h-11 border border-slate-200 dark:border-slate-700 rounded-xl cursor-pointer">
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Background</label>
            <input type="color" name="bg_color" value="<%= qr.bg_color %>" class="w-full h-11 border border-slate-200 dark:border-slate-700 rounded-xl cursor-pointer">
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Style</label>
            <select name="dot_style" class="w-full px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all">
              <option value="square" <%= qr.dot_style === 'square' ? 'selected' : '' %>>Square</option>
              <option value="rounded" <%= qr.dot_style === 'rounded' ? 'selected' : '' %>>Rounded</option>
              <option value="circle" <%= qr.dot_style === 'circle' ? 'selected' : '' %>>Dots</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Access Control -->
      <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 shadow-card border border-slate-200/60 dark:border-slate-800/60">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-9 h-9 rounded-xl bg-amber-50 dark:bg-amber-500/10 flex items-center justify-center">
            <i data-lucide="shield" class="w-4 h-4 text-amber-600 dark:text-amber-400"></i>
          </div>
          <h2 class="font-semibold text-slate-900 dark:text-white">Access Control</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">New Password <span class="text-slate-400 text-xs font-normal">(leave blank to keep)</span></label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i data-lucide="lock" class="w-4 h-4 text-slate-400"></i></div>
              <input type="text" name="password" placeholder="••••••" maxlength="128" class="w-full pl-10 pr-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
            </div>
            <% if (qr.password_hash) { %>
              <label class="flex items-center gap-2 mt-2 text-xs text-slate-500 dark:text-slate-400 cursor-pointer">
                <input type="checkbox" name="password_clear" value="__clear__" form="password-form" class="rounded-lg border-slate-300 dark:border-slate-600 text-brand-600 focus:ring-brand-500/30">
                Remove password
              </label>
            <% } %>
          </div>
          <% if (qr.content_type === 'file') { %>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Verification Code <span class="text-slate-400 text-xs font-normal">(leave blank to keep)</span></label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i data-lucide="key-round" class="w-4 h-4 text-slate-400"></i></div>
              <input type="text" name="verify_code" placeholder="New code" maxlength="128" class="w-full pl-10 pr-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
            </div>
          </div>
          <% } %>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Expires At</label>
            <input type="datetime-local" name="expires_at" value="<%= qr.expires_at ? qr.expires_at.substring(0, 16) : '' %>" class="w-full px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all">
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Scan Limit</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i data-lucide="hash" class="w-4 h-4 text-slate-400"></i></div>
              <input type="number" name="scan_limit" min="0" max="9999999" value="<%= qr.scan_limit || '' %>" placeholder="Unlimited" class="w-full pl-10 pr-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
            </div>
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Tags <span class="text-slate-400 text-xs font-normal">(comma-separated)</span></label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i data-lucide="tag" class="w-4 h-4 text-slate-400"></i></div>
              <input type="text" name="tags" value="<%= qr.tags || '' %>" maxlength="500" placeholder="marketing, campaign-2026" class="w-full pl-10 pr-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
            </div>
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Internal Notes</label>
            <textarea name="notes" rows="2" maxlength="2000" class="w-full px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow"><%= qr.notes || '' %></textarea>
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Webhook URL <span class="text-slate-400 text-xs font-normal">(notified on scan)</span></label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i data-lucide="webhook" class="w-4 h-4 text-slate-400"></i></div>
              <input type="url" name="webhook_url" value="<%= qr.webhook_url || '' %>" maxlength="500" placeholder="https://your-api.com/webhook" class="w-full pl-10 pr-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
            </div>
          </div>
        </div>
        <div class="mt-5 pt-5 border-t border-slate-100 dark:border-slate-800">
          <label class="flex items-center gap-2.5 text-sm text-slate-700 dark:text-slate-300 cursor-pointer">
            <input type="checkbox" name="is_active" value="1" <%= qr.is_active ? 'checked' : '' %> class="rounded-lg border-slate-300 dark:border-slate-600 text-brand-600 focus:ring-brand-500/30">
            <span class="font-medium">Active</span>
            <span class="text-slate-400 dark:text-slate-500 text-xs font-normal">(uncheck to deactivate without deleting)</span>
          </label>
        </div>
      </div>

      <button id="save-btn" type="submit" class="w-full bg-gradient-to-r from-brand-600 to-violet-600 text-white py-3 rounded-xl hover:from-brand-700 hover:to-violet-700 font-semibold text-sm transition-all btn-scale shadow-glow hover:shadow-glow-lg animate-glow-pulse">
        Save Changes
      </button>
    </form>

    <!-- QR Preview Sidebar -->
    <div class="bg-white dark:bg-slate-900 p-5 rounded-2xl shadow-card border border-slate-200/60 dark:border-slate-800/60 h-fit sticky top-24">
      <div class="flex items-center gap-2 mb-4">
        <i data-lucide="eye" class="w-4 h-4 text-slate-400"></i>
        <h3 class="font-semibold text-sm text-slate-900 dark:text-white">Current QR</h3>
      </div>
      <div class="bg-white rounded-xl p-3 mb-4 border border-slate-100">
        <img src="/qr-image-public/<%= qr.id %>" alt="QR" class="w-full" id="qr-preview">
      </div>
      <div class="space-y-2.5 text-xs mb-4">
        <div class="flex justify-between">
          <span class="text-slate-500 dark:text-slate-400">Scans</span>
          <span class="font-mono font-bold text-slate-900 dark:text-white"><%= qr.scan_count %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-slate-500 dark:text-slate-400">Status</span>
          <span class="<%= qr.is_active ? 'badge badge-green' : 'badge badge-red' %>"><%= qr.is_active ? 'Active' : 'Inactive' %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-slate-500 dark:text-slate-400">Created</span>
          <span class="text-slate-700 dark:text-slate-300"><%= qr.created_at %></span>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-2 mb-3">
