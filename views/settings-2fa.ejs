<%- include('partials/header') %>
<div class="max-w-md mx-auto mt-8 fade-in">
  <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border dark:border-gray-700">
    <h1 class="text-xl font-bold dark:text-white mb-2">Enable Two-Factor Auth</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Scan this QR code with Google Authenticator, Authy, or 1Password, then enter the 6-digit code below.</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-100 dark:bg-red-900 border border-red-400 dark:border-red-700 text-red-700 dark:text-red-300 px-4 py-3 rounded mb-4 text-sm"><%= error %></div>
    <% } %>

    <div class="text-center bg-gray-50 dark:bg-gray-900 p-4 rounded-lg mb-4">
      <img src="<%= qr %>" alt="2FA QR Code" class="mx-auto w-48 h-48">
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-2 font-mono break-all"><%= secret %></p>
    </div>

    <form method="POST" action="/settings/2fa/verify">
      <input type="hidden" name="_csrf" value="<%= _csrf %>">
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Verification Code</label>
      <input type="text" name="code" required pattern="[0-9]{6}" inputmode="numeric" maxlength="6" placeholder="123456" autofocus class="w-full px-3 py-2 text-center text-2xl font-mono border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none mb-3">
      <button type="submit" class="w-full bg-indigo-600 text-white py-2.5 rounded-lg hover:bg-indigo-700 font-medium text-sm btn-scale">Verify & Enable</button>
    </form>

    <a href="/settings?tab=security" class="block text-center text-sm text-gray-500 dark:text-gray-400 hover:underline mt-3">Cancel</a>
  </div>
</div>
<%- include('partials/footer') %>
