<%- include('partials/header') %>
<div class="max-w-md mx-auto mt-8 sm:mt-16 px-4 fade-in">
  <div class="bg-white dark:bg-gray-800 p-6 sm:p-8 rounded-xl shadow-md dark:shadow-2xl border dark:border-gray-700 text-center">
    <div class="text-5xl mb-4">🔒</div>
    <h1 class="text-xl font-bold mb-2 dark:text-white">Protected Content</h1>
    <p class="text-gray-500 dark:text-gray-400 text-sm mb-6">This QR code is password protected.</p>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-100 dark:bg-red-900 border border-red-400 dark:border-red-700 text-red-700 dark:text-red-300 px-4 py-3 rounded mb-4 text-sm"><%= error %></div>
    <% } %>
    <form method="POST" action="/q/<%= qrId %>" onsubmit="document.getElementById('unlock-btn').disabled=true;document.getElementById('unlock-btn').innerHTML='<span class=\\'spinner\\'></span>'">
      <input type="hidden" name="_csrf" value="<%= _csrf %>">
      <input type="password" name="password" placeholder="Enter password" required
        class="w-full px-4 py-3 border-2 dark:border-gray-600 rounded-lg mb-4 text-center text-lg bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 focus:outline-none">
      <button id="unlock-btn" type="submit" class="btn-scale w-full bg-indigo-600 text-white py-3 rounded-lg hover:bg-indigo-700 font-medium text-lg transition-colors">
        Unlock
      </button>
    </form>
  </div>
</div>
<%- include('partials/footer') %>
