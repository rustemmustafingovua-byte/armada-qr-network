<%- include('partials/header') %>
<div class="max-w-md mx-auto mt-8 sm:mt-16 px-4">
  <div class="bg-white p-6 sm:p-8 rounded-xl shadow-md border text-center">
    <div class="text-5xl mb-4">🔒</div>
    <h1 class="text-xl font-bold mb-2">Protected Content</h1>
    <p class="text-gray-500 text-sm mb-6">This QR code is password protected.</p>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4 text-sm"><%= error %></div>
    <% } %>
    <form method="POST" action="/q/<%= qrId %>">
      <input type="password" name="password" placeholder="Enter password" required
        class="w-full px-4 py-3 border-2 rounded-lg mb-4 text-center text-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 focus:outline-none">
      <button type="submit" class="btn-scale w-full bg-indigo-600 text-white py-3 rounded-lg hover:bg-indigo-700 font-medium text-lg active:bg-indigo-800">
        Unlock
      </button>
    </form>
  </div>
</div>
<%- include('partials/footer') %>
