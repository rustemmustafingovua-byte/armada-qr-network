<%- include('partials/header') %>
<div class="max-w-md mx-auto mt-8 sm:mt-16 px-4 fade-in">
  <div class="bg-white dark:bg-slate-900 p-8 rounded-2xl shadow-card dark:shadow-2xl border border-slate-200/60 dark:border-slate-800/60 text-center">
    <div class="w-16 h-16 mx-auto rounded-2xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center mb-5">
      <i data-lucide="lock" class="w-8 h-8 text-slate-400"></i>
    </div>
    <h1 class="text-xl font-bold mb-2 text-slate-900 dark:text-white">Protected Content</h1>
    <% if (title) { %><p class="text-slate-600 dark:text-slate-400 text-sm mb-2 font-medium"><%= title %></p><% } %>
    <p class="text-slate-500 dark:text-slate-400 text-sm mb-6">This QR code is password protected.</p>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="flex items-center gap-2 bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 text-red-700 dark:text-red-400 px-4 py-3 rounded-xl mb-5 text-sm slide-down">
        <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i>
        <span><%= error %></span>
      </div>
    <% } %>
    <form method="POST" action="/q/<%= qrId %>" onsubmit="document.getElementById('unlock-btn').disabled=true;document.getElementById('unlock-btn').innerHTML='<span class=\\'spinner\\'></span>'">
      <input type="hidden" name="_csrf" value="<%= _csrf %>">
      <div class="relative mb-4">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i data-lucide="lock" class="w-4 h-4 text-slate-400"></i></div>
        <input type="password" name="password" placeholder="Enter password" required autofocus
          class="w-full pl-10 pr-4 py-3 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-center text-lg focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
      </div>
      <button id="unlock-btn" type="submit" class="w-full bg-gradient-to-r from-brand-600 to-violet-600 text-white py-3 rounded-xl hover:from-brand-700 hover:to-violet-700 font-semibold text-sm btn-scale shadow-glow hover:shadow-glow-lg transition-all">
        Unlock
      </button>
    </form>
  </div>
</div>
<script>document.addEventListener('DOMContentLoaded', function() { if (window.lucide) lucide.createIcons(); });</script>
<%- include('partials/footer') %>
