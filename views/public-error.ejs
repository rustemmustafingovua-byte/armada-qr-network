<%- include('partials/header') %>
<div class="max-w-md mx-auto mt-8 sm:mt-16 px-4 fade-in">
  <div class="bg-white dark:bg-slate-900 p-8 rounded-2xl shadow-card dark:shadow-2xl border border-slate-200/60 dark:border-slate-800/60 text-center">
    <div class="w-16 h-16 mx-auto rounded-2xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center mb-5">
      <% if (code === 404) { %><i data-lucide="search-x" class="w-8 h-8 text-slate-400"></i>
      <% } else if (code === 403) { %><i data-lucide="shield-x" class="w-8 h-8 text-slate-400"></i>
      <% } else if (code === 429) { %><i data-lucide="clock" class="w-8 h-8 text-slate-400"></i>
      <% } else if (code === 413) { %><i data-lucide="file-warning" class="w-8 h-8 text-slate-400"></i>
      <% } else { %><i data-lucide="alert-triangle" class="w-8 h-8 text-slate-400"></i><% } %>
    </div>
    <h1 class="text-xl font-bold mb-2 text-slate-900 dark:text-white">Error <%= code %></h1>
    <p class="text-slate-500 dark:text-slate-400 text-base mb-6"><%= message %></p>
    <a href="/" class="inline-flex items-center gap-1.5 text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300 text-sm font-medium transition-colors">
      <i data-lucide="arrow-left" class="w-4 h-4"></i> Go home
    </a>
  </div>
</div>
<script>document.addEventListener('DOMContentLoaded', function() { if (window.lucide) lucide.createIcons(); });</script>
<%- include('partials/footer') %>
