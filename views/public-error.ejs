<%- include('partials/header') %>
<div class="max-w-md mx-auto mt-8 sm:mt-16 px-4 fade-in">
  <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-md dark:shadow-2xl border dark:border-gray-700 text-center">
    <div class="text-5xl mb-4">
      <% if (code === 404) { %>🔍
      <% } else if (code === 403) { %>🚫
      <% } else if (code === 429) { %>⏱
      <% } else if (code === 413) { %>📦
      <% } else { %>⚠️<% } %>
    </div>
    <h1 class="text-xl font-bold mb-2 dark:text-white">Error <%= code %></h1>
    <p class="text-gray-500 dark:text-gray-400 text-base"><%= message %></p>
    <a href="/" class="inline-block mt-4 text-indigo-600 dark:text-indigo-400 hover:underline text-sm">← Go home</a>
  </div>
</div>
<%- include('partials/footer') %>
