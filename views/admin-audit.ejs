<%- include('partials/header') %>
<div class="fade-in">
  <div class="flex items-center justify-between mb-8">
    <div class="flex items-center gap-3">
      <a href="/admin" class="p-2 rounded-lg text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-all"><i data-lucide="arrow-left" class="w-5 h-5"></i></a>
      <div>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Audit Log</h1>
        <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">System activity and security events</p>
      </div>
    </div>
  </div>

  <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-card border border-slate-200/60 dark:border-slate-800/60 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="text-xs text-slate-400 dark:text-slate-500 uppercase tracking-wider bg-slate-50 dark:bg-slate-800/50">
          <tr>
            <th class="text-left px-5 py-3.5 font-semibold">Time</th>
            <th class="text-left px-5 py-3.5 font-semibold">User</th>
            <th class="text-left px-5 py-3.5 font-semibold">Event</th>
            <th class="text-left px-5 py-3.5 font-semibold">Details</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
          <% entries.forEach(function(e) { %>
          <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
            <td class="px-5 py-3 text-xs text-slate-500 dark:text-slate-400 whitespace-nowrap"><%= e.created_at %></td>
            <td class="px-5 py-3 text-xs font-medium text-slate-900 dark:text-white"><%= e.email || 'system' %></td>
            <td class="px-5 py-3"><span class="badge badge-gray font-mono text-[10px]"><%= e.event %></span></td>
            <td class="px-5 py-3 text-xs text-slate-400 dark:text-slate-500 font-mono truncate max-w-md"><%= e.details %></td>
          </tr>
          <% }); %>
          <% if (entries.length === 0) { %><tr><td colspan="4" class="px-5 py-8 text-center text-slate-400 dark:text-slate-500">No events yet</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<script>document.addEventListener('DOMContentLoaded', function() { if (window.lucide) lucide.createIcons(); });</script>
<%- include('partials/footer') %>
