<%- include('partials/header') %>
<div class="max-w-4xl mx-auto fade-in">
  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white tracking-tight">Settings</h1>
      <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Manage your account and preferences</p>
    </div>
    <a href="/dashboard" class="flex items-center gap-1.5 text-sm font-medium text-slate-500 hover:text-brand-600 dark:text-slate-400 dark:hover:text-brand-400 transition-colors">
      <i data-lucide="arrow-left" class="w-4 h-4"></i>
      Dashboard
    </a>
  </div>

  <% if (typeof success !== 'undefined' && success) { %>
    <div class="flex items-center gap-2 bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/20 text-emerald-700 dark:text-emerald-400 px-4 py-3 rounded-xl mb-5 text-sm slide-down" data-flash>
      <i data-lucide="check-circle" class="w-4 h-4 flex-shrink-0"></i>
      <span><%= success %></span>
    </div>
  <% } %>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="flex items-center gap-2 bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 text-red-700 dark:text-red-400 px-4 py-3 rounded-xl mb-5 text-sm slide-down" data-flash>
      <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i>
      <span><%= error %></span>
    </div>
  <% } %>

  <!-- Tabs -->
  <div class="flex gap-2 mb-8 overflow-x-auto pb-2">
    <a href="/settings?tab=profile" class="tab-pill flex items-center gap-1.5 px-4 py-2 text-sm font-medium rounded-xl whitespace-nowrap transition-all <%= tab === 'profile' ? 'tab-pill active' : 'text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800' %>">
      <i data-lucide="user" class="w-4 h-4"></i> Profile
    </a>
    <a href="/settings?tab=security" class="tab-pill flex items-center gap-1.5 px-4 py-2 text-sm font-medium rounded-xl whitespace-nowrap transition-all <%= tab === 'security' ? 'tab-pill active' : 'text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800' %>">
      <i data-lucide="shield" class="w-4 h-4"></i> Security
    </a>
    <a href="/settings?tab=tokens" class="tab-pill flex items-center gap-1.5 px-4 py-2 text-sm font-medium rounded-xl whitespace-nowrap transition-all <%= tab === 'tokens' ? 'tab-pill active' : 'text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800' %>">
      <i data-lucide="key-round" class="w-4 h-4"></i> API Tokens
    </a>
    <a href="/settings?tab=data" class="tab-pill flex items-center gap-1.5 px-4 py-2 text-sm font-medium rounded-xl whitespace-nowrap transition-all <%= tab === 'data' ? 'tab-pill active' : 'text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800' %>">
      <i data-lucide="database" class="w-4 h-4"></i> Data
    </a>
  </div>

  <% if (tab === 'profile') { %>
  <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 shadow-card border border-slate-200/60 dark:border-slate-800/60 space-y-6">
    <form method="POST" action="/settings/profile" class="space-y-4">
      <input type="hidden" name="_csrf" value="<%= _csrf %>">
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Name</label>
        <input type="text" name="name" value="<%= user.name || '' %>" maxlength="100" class="w-full px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Email</label>
        <input type="email" value="<%= user.email %>" disabled class="w-full px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-slate-50 dark:bg-slate-800/50 text-slate-500 dark:text-slate-400 text-sm">
        <p class="text-xs text-slate-400 dark:text-slate-500 mt-1.5">To change email, use the form below</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Language</label>
        <select name="language" class="w-full px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all">
          <option value="en" <%= user.language === 'en' ? 'selected' : '' %>>English</option>
          <option value="ru" <%= user.language === 'ru' ? 'selected' : '' %>>Русский</option>
        </select>
      </div>
      <div class="flex items-center gap-2.5">
        <input type="checkbox" name="email_notifications" id="en" <%= user.email_notifications ? 'checked' : '' %> class="rounded-lg border-slate-300 dark:border-slate-600 text-brand-600 focus:ring-brand-500/30">
        <label for="en" class="text-sm text-slate-700 dark:text-slate-300">Email me about new messages and scan milestones</label>
      </div>
      <button type="submit" class="bg-gradient-to-r from-brand-600 to-violet-600 text-white px-5 py-2.5 rounded-xl hover:from-brand-700 hover:to-violet-700 font-semibold text-sm btn-scale shadow-glow hover:shadow-glow-lg">Save Profile</button>
    </form>
    <div class="section-divider"></div>
    <details class="text-sm">
      <summary class="cursor-pointer text-brand-600 dark:text-brand-400 font-medium flex items-center gap-1.5"><i data-lucide="mail" class="w-4 h-4"></i> Change email</summary>
      <form method="POST" action="/settings/email" class="mt-4 space-y-3">
        <input type="hidden" name="_csrf" value="<%= _csrf %>">
        <input type="email" name="email" placeholder="new@example.com" required class="w-full px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
        <input type="password" name="password" placeholder="Current password" required class="w-full px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
        <button type="submit" class="bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 px-4 py-2 rounded-xl hover:bg-slate-200 dark:hover:bg-slate-700 font-medium text-sm transition-all">Update Email</button>
      </form>
    </details>
  </div>
  <% } %>

  <% if (tab === 'security') { %>
  <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 shadow-card border border-slate-200/60 dark:border-slate-800/60 space-y-6">
    <form method="POST" action="/settings/password" class="space-y-4">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-9 h-9 rounded-xl bg-brand-50 dark:bg-brand-500/10 flex items-center justify-center"><i data-lucide="key-round" class="w-4 h-4 text-brand-600 dark:text-brand-400"></i></div>
        <h3 class="font-semibold text-slate-900 dark:text-white">Change Password</h3>
      </div>
      <input type="hidden" name="_csrf" value="<%= _csrf %>">
      <input type="password" name="current_password" placeholder="Current password" required class="w-full px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
      <input type="password" name="new_password" placeholder="New password (min 8 chars, letters + numbers)" required minlength="8" class="w-full px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
      <button type="submit" class="bg-gradient-to-r from-brand-600 to-violet-600 text-white px-5 py-2.5 rounded-xl hover:from-brand-700 hover:to-violet-700 font-semibold text-sm btn-scale shadow-glow hover:shadow-glow-lg">Update Password</button>
    </form>
    <div class="section-divider"></div>
    <div>
      <div class="flex items-center gap-3 mb-3">
        <div class="w-9 h-9 rounded-xl bg-emerald-50 dark:bg-emerald-500/10 flex items-center justify-center"><i data-lucide="shield-check" class="w-4 h-4 text-emerald-600 dark:text-emerald-400"></i></div>
        <h3 class="font-semibold text-slate-900 dark:text-white">Two-Factor Authentication</h3>
      </div>
      <p class="text-sm text-slate-500 dark:text-slate-400 mb-4 ml-12">
        <% if (user.totp_enabled) { %>
          <span class="badge badge-green"><i data-lucide="check" class="w-3 h-3"></i> Enabled</span> — You'll need a code from your authenticator app to sign in.
        <% } else { %>
          Add an extra layer of security with TOTP (Google Authenticator, Authy, etc.)
        <% } %>
      </p>
      <% if (!user.totp_enabled) { %>
        <form method="POST" action="/settings/2fa/enable" class="ml-12">
          <input type="hidden" name="_csrf" value="<%= _csrf %>">
          <button type="submit" class="bg-gradient-to-r from-brand-600 to-violet-600 text-white px-5 py-2.5 rounded-xl hover:from-brand-700 hover:to-violet-700 font-semibold text-sm btn-scale shadow-glow hover:shadow-glow-lg">Enable 2FA</button>
        </form>
      <% } else { %>
        <details class="ml-12">
          <summary class="text-sm text-red-500 dark:text-red-400 cursor-pointer font-medium flex items-center gap-1"><i data-lucide="shield-off" class="w-3.5 h-3.5"></i> Disable 2FA</summary>
          <form method="POST" action="/settings/2fa/disable" class="mt-3 space-y-3">
            <input type="hidden" name="_csrf" value="<%= _csrf %>">
            <input type="password" name="password" placeholder="Confirm with your password" required class="w-full px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
            <button type="submit" class="bg-red-500 text-white px-4 py-2 rounded-xl hover:bg-red-600 font-medium text-sm transition-all">Disable 2FA</button>
          </form>
        </details>
      <% } %>
    </div>
  </div>
  <% } %>

  <% if (tab === 'tokens') { %>
  <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 shadow-card border border-slate-200/60 dark:border-slate-800/60">
    <% if (typeof new_token !== 'undefined' && new_token) { %>
    <div class="bg-amber-50 dark:bg-amber-500/10 border border-amber-200 dark:border-amber-500/20 p-4 rounded-xl mb-6">
      <div class="flex items-center gap-2 mb-2">
        <i data-lucide="alert-triangle" class="w-4 h-4 text-amber-600 dark:text-amber-400"></i>
        <p class="text-sm font-semibold text-amber-700 dark:text-amber-400">Save this token — you won't see it again:</p>
      </div>
      <code class="block bg-amber-100 dark:bg-amber-500/10 text-amber-800 dark:text-amber-300 p-3 rounded-lg font-mono text-sm break-all select-all border border-amber-200 dark:border-amber-500/20"><%= new_token %></code>
      <p class="text-xs text-amber-600 dark:text-amber-500 mt-2">Use: <code class="bg-amber-100 dark:bg-amber-500/10 px-1.5 py-0.5 rounded">Authorization: Bearer &lt;token&gt;</code></p>
    </div>
    <% } %>

    <form method="POST" action="/settings/tokens" class="flex flex-col sm:flex-row gap-3 mb-6">
      <input type="hidden" name="_csrf" value="<%= _csrf %>">
      <div class="relative flex-1">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i data-lucide="tag" class="w-4 h-4 text-slate-400"></i></div>
        <input type="text" name="name" placeholder="Token name (e.g. CI/CD, Mobile app)" required maxlength="100" class="w-full pl-10 pr-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-800 dark:text-white text-sm focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:outline-none transition-all input-glow">
      </div>
      <button type="submit" class="flex items-center gap-1.5 bg-gradient-to-r from-brand-600 to-violet-600 text-white px-5 py-2.5 rounded-xl hover:from-brand-700 hover:to-violet-700 font-semibold text-sm btn-scale shadow-glow hover:shadow-glow-lg whitespace-nowrap">
        <i data-lucide="plus" class="w-4 h-4"></i> New Token
      </button>
    </form>

    <h3 class="font-semibold text-xs text-slate-400 dark:text-slate-500 uppercase tracking-wider mb-3">Your API Tokens</h3>
    <% if (tokens.length === 0) { %>
      <div class="text-center py-8">
        <div class="w-14 h-14 mx-auto rounded-2xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center mb-3"><i data-lucide="key-round" class="w-7 h-7 text-slate-300 dark:text-slate-600"></i></div>
        <p class="text-sm text-slate-400 dark:text-slate-500">No tokens yet. Create one to use the REST API.</p>
      </div>
    <% } else { %>
    <table class="w-full text-sm">
      <thead class="text-xs text-slate-400 dark:text-slate-500 uppercase tracking-wider">
        <tr><th class="text-left px-3 py-2.5 font-semibold">Name</th><th class="text-left px-3 py-2.5 font-semibold">Prefix</th><th class="text-left px-3 py-2.5 font-semibold">Last Used</th><th class="text-right px-3 py-2.5 font-semibold">Actions</th></tr>
      </thead>
      <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
        <% tokens.forEach(function(t) { %>
        <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
          <td class="px-3 py-3 font-medium text-slate-900 dark:text-white"><%= t.name %></td>
          <td class="px-3 py-3 font-mono text-xs text-slate-400"><%= t.prefix %>&hellip;</td>
          <td class="px-3 py-3 text-xs text-slate-400"><%= t.last_used_at || 'Never' %></td>
          <td class="px-3 py-3 text-right">
            <form method="POST" action="/settings/tokens/<%= t.id %>/delete" class="inline" onsubmit="return confirm('Revoke this token?')">
              <input type="hidden" name="_csrf" value="<%= _csrf %>">
              <button class="text-red-500 dark:text-red-400 hover:text-red-700 hover:underline text-xs font-medium transition-colors">Revoke</button>
            </form>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
    <% } %>

    <div class="section-divider my-6"></div>
    <details>
      <summary class="text-sm text-brand-600 dark:text-brand-400 cursor-pointer font-medium flex items-center gap-1.5"><i data-lucide="book-open" class="w-4 h-4"></i> API Documentation</summary>
      <pre class="mt-3 bg-slate-50 dark:bg-slate-800/50 p-4 rounded-xl text-xs overflow-x-auto text-slate-600 dark:text-slate-300 border border-slate-100 dark:border-slate-800 font-mono"><code>GET    /api/v1/qr           — list your QR codes
GET    /api/v1/qr/:id       — get specific QR
POST   /api/v1/qr           — create QR (JSON body)
DELETE /api/v1/qr/:id       — delete QR
GET    /api/v1/analytics/:id — get analytics
GET    /api/v1/messages/:id  — get messages

Auth: Authorization: Bearer &lt;token&gt;</code></pre>
    </details>
  </div>
  <% } %>

  <% if (tab === 'data') { %>
  <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 shadow-card border border-slate-200/60 dark:border-slate-800/60 space-y-6">
    <div>
      <div class="flex items-center gap-3 mb-2">
        <div class="w-9 h-9 rounded-xl bg-brand-50 dark:bg-brand-500/10 flex items-center justify-center"><i data-lucide="download" class="w-4 h-4 text-brand-600 dark:text-brand-400"></i></div>
        <h3 class="font-semibold text-slate-900 dark:text-white">Export Your Data</h3>
      </div>
      <p class="text-sm text-slate-500 dark:text-slate-400 mb-4 ml-12">Download all your QR codes, analytics, and messages as JSON.</p>
      <a href="/settings/export" class="ml-12 inline-flex items-center gap-1.5 bg-gradient-to-r from-brand-600 to-violet-600 text-white px-5 py-2.5 rounded-xl hover:from-brand-700 hover:to-violet-700 font-semibold text-sm btn-scale shadow-glow hover:shadow-glow-lg">
        <i data-lucide="download" class="w-4 h-4"></i> Download JSON
      </a>
    </div>
    <div class="section-divider"></div>
    <div>
      <div class="flex items-center gap-3 mb-2">
        <div class="w-9 h-9 rounded-xl bg-red-50 dark:bg-red-500/10 flex items-center justify-center"><i data-lucide="alert-triangle" class="w-4 h-4 text-red-600 dark:text-red-400"></i></div>
        <h3 class="font-semibold text-red-600 dark:text-red-400">Danger Zone</h3>
      </div>
      <p class="text-sm text-slate-500 dark:text-slate-400 ml-12">Account deletion is permanent and cannot be undone.</p>
      <p class="text-xs text-slate-400 dark:text-slate-500 mt-2 ml-12">Contact support@armada.com to delete your account.</p>
    </div>
  </div>
  <% } %>
</div>
<script>document.addEventListener('DOMContentLoaded', function() { if (window.lucide) lucide.createIcons(); });</script>
<%- include('partials/footer') %>
