<%- include('partials/header') %>
<div class="max-w-md mx-auto mt-16 fade-in">
  <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-md dark:shadow-2xl">
    <div class="text-center mb-6">
      <div class="text-4xl mb-2">📱</div>
      <h1 class="text-2xl font-bold dark:text-white">Armada QR Network</h1>
      <p class="text-gray-500 dark:text-gray-400 text-sm mt-1">Sign in to your account</p>
    </div>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-100 dark:bg-red-900 border border-red-400 dark:border-red-700 text-red-700 dark:text-red-300 px-4 py-3 rounded mb-4 text-sm"><%= error %></div>
    <% } %>
    <form method="POST" action="/login" onsubmit="document.getElementById('login-btn').disabled=true;document.getElementById('login-btn').innerHTML='<span class=\\'spinner\\'></span>'">
      <input type="hidden" name="_csrf" value="<%= _csrf %>">
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Email</label>
        <input type="email" name="email" required value="<%= typeof email !== 'undefined' ? email : '' %>" autocomplete="email" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Password</label>
        <input type="password" name="password" required autocomplete="current-password" class="w-full px-3 py-2 border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
      </div>
      <% if (typeof requireTotp !== 'undefined' && requireTotp) { %>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">2FA Code</label>
        <input type="text" name="totp" pattern="[0-9]{6}" inputmode="numeric" maxlength="6" required autofocus placeholder="123456" class="w-full px-3 py-2 text-center text-xl font-mono border dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
      </div>
      <% } %>
      <button id="login-btn" type="submit" class="w-full bg-indigo-600 text-white py-2.5 rounded-lg hover:bg-indigo-700 font-medium transition-colors">Sign In</button>
    </form>
    <p class="text-center text-sm text-gray-500 dark:text-gray-400 mt-4">Don't have an account? <a href="/register" class="text-indigo-600 dark:text-indigo-400 hover:underline">Register</a></p>
  </div>
</div>
<%- include('partials/footer') %>
